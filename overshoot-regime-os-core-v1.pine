//@version=6
indicator("Jamal Phase 1 v5", shorttitle="Jamal P1v5", overlay=false)

// =====================================================================
// OS core = overshoot fader + REGIME (now a CONDITIONER, not a veto).
//
// PIVOT (after the v4 sweep): Phase-1 veto-only failed gate-0 on an exit-blind
// 24-bar horizon return. Mean-reversion edge is FRONT-LOADED, so a fixed hold
// measures the decayed endpoint, not the catchable bounce. v5 replaces the
// outcome metric with a TRIPLE-BARRIER first-touch (target / stop / time cap),
// which captures sequence (which barrier hit first) and yields tradeable
// expectancy + target-hit vs stop-hit rates (the ex-ante bounce-vs-knife test).
// Regime is retained as a conditioning slice (Taken vs Veto-DIR vs Veto-CSC),
// NOT as a live veto verdict.
//
// BOUNDED TO TRADINGVIEW: no external/CPCV. Overfit-robustness comes from the
// multi-symbol x multi-TF sweep, effective-n + SE/t significance, and parameter
// perturbation. Still NOT a backtest: descriptive, cost-blind, overlapping.
//
// REGIME axes (unchanged from v3/v4):
//   TREND  : Kaufman ER (drift-aware; ABSOLUTE Schmitt enter/exit). DIRECTION: projected
//            linreg slope, ATR deadband. VOL: ATR percentile + volume surge -> cascade.
//   STABILITY: signed-regime state machine + min dwell; cascade = priority interrupt.
//   (ac1 / variance-ratio kept as READOUTS only - mean-centered, blind to drift.)
//
// SCOUT (v5): per signal, scan the forward window for first touch of +target*ATR,
//   -stop*ATR, or the time cap. Outcome in ATR. Buckets: Taken / Veto-DIR / Veto-CSC
//   per side, each vs a random-bar baseline (same bracket). Exp = mean(bucket) -
//   mean(baseline), with SE from EFFECTIVE-n (non-overlapping) -> read only |t|>=1.5.
//   GATE-0 = the Taken row Exp (does the fader beat random entries?). "gate d" rows =
//   Taken - Veto-DIR (regime's marginal value). tH%/sH% = target/stop first-touch rates.
//   MFE = mean favorable excursion (front-loading tell: MFE>>Exp => edge handed back).
// =====================================================================

// ===== Inputs =====
// --- Regime ---
regime_filter   = input.bool(true,  "Apply regime veto (live plot only)", group="Regime", tooltip="Live arrows/alerts gating only. The scout's Taken/Veto split is computed from regime regardless (conditioner), so analysis is unaffected by this toggle.")
er_len          = input.int(20,   "Efficiency Ratio length",      minval=5,                         group="Regime", tooltip="Kaufman ER = |net change| / sum(|bar changes|) over N. 0..1. NOT mean-centered -> sees drift directly. Trend-strength detector.")
er_trend        = input.float(0.30, "ER trend ENTER threshold",    minval=0.05, maxval=0.95, step=0.01, group="Regime", tooltip="Schmitt ENTER. ABSOLUTE cut (do not percentile-normalize). 0.30 calibrated for 1h crypto.")
er_exit         = input.float(0.18, "ER trend EXIT threshold",     minval=0.01, maxval=0.95, step=0.01, group="Regime", tooltip="Schmitt EXIT (clamped <= ENTER). Dead band damps single-cutoff flicker.")
regime_min_dwell = input.int(3,   "Regime minimum dwell (bars)",  minval=1,                         group="Regime", tooltip="A label change must persist this many bars (cascade overrides instantly).")
ac_len          = input.int(50,   "Autocorr length (lag-1) [READOUT]", minval=10,                   group="Regime", tooltip="READOUT ONLY. Mean-centered -> blind to drift; reversion lens (<0 = reversion).")
vr_k            = input.int(5,    "Variance-ratio horizon k [READOUT]", minval=2,                   group="Regime", tooltip="Readout horizon.")
vr_len          = input.int(50,   "Variance-ratio sample length [READOUT]", minval=20,              group="Regime", tooltip="Readout window. VR>1 persistent, <1 mean-reverting; mean-centered -> ~1 for drift.")
vol_pct_len     = input.int(250,  "Vol percentile lookback",      minval=50,                        group="Regime", tooltip="History for ranking current ATR.")
vol_hi          = input.float(80,   "Vol-hot percentile (cascade)", minval=50, maxval=99, step=1,     group="Regime", tooltip="ATR percentile >= this = vol expansion (a cascade condition).")
er_cascade      = input.float(0.45, "ER cascade threshold",        minval=0.3, maxval=0.99, step=0.01, group="Regime", tooltip="ER + hot vol + volume surge = cascade. Replay-validated tail guard, not statistical; don't over-tune.")
vsma_len        = input.int(20,   "Volume MA length (surge)",     minval=5,                         group="Regime", tooltip="Baseline for the volume-surge test.")
vsurge_mult     = input.float(1.8,  "Volume surge multiple",        minval=1.0, step=0.1,             group="Regime", tooltip="volume > mult * SMA(volume) = surge.")
slope_dead_atr  = input.float(0.05, "Trend slope deadband (ATR/bar)", minval=0.0, step=0.01,         group="Regime", tooltip="Min |projected linreg slope|/ATR per bar to count as directional. The binding directional gate.")

// --- Arrows ---
use_reversion = input.bool(false, "Fire on reversion (1 per episode)", group="Arrows", tooltip="ON: arm on extreme, fire once on contraction back inside the band. OFF: every extreme bar fires.")
arm_max_bars  = input.int(24, "Reversion arm timeout (bars)", minval=1, group="Arrows", tooltip="Armed setup self-clears after this many bars.")

// --- Display ---
show_turns       = input.bool(true,  "Show fade arrows on price", group="Display")
show_provisional = input.bool(true,  "Show provisional (forming-bar) signals", group="Display")
show_table       = input.bool(true,  "Show state panel (top-right)", group="Display")
show_scout       = input.bool(true,  "Show scout dashboard (bottom-right)", group="Display", tooltip="Triple-barrier expectancy with error bars: Taken vs Veto-DIR vs Veto-CSC per side. NOT a backtest.")
show_regime_bg   = input.bool(true,  "Tint pane by regime", group="Display")
os_color_mode    = input.string("State", "Overshoot column color", options=["State", "Direction"], group="Display")

// --- Scout sampling / barrier ---
fwd_bars      = input.int(24,  "Forward window (bars)",     minval=2,                group="Scout", tooltip="Max forward bars held in history for the barrier scan + the overlap length for effective-n. Must be >= time cap.")
bar_target_atr = input.float(1.0, "Barrier target (ATR)",   minval=0.1, step=0.1,    group="Scout", tooltip="Take-profit distance in ATR (favorable). Tight for a fader = harvest the brief bounce.")
bar_stop_atr   = input.float(1.5, "Barrier stop (ATR)",     minval=0.1, step=0.1,    group="Scout", tooltip="Stop distance in ATR (adverse). The 1R risk unit.")
bar_tcap       = input.int(12, "Barrier time cap (bars)",   minval=1,                group="Scout", tooltip="Max hold; on timeout, exit at that bar's close. Clamped to <= forward window. Short = don't hold into continuation.")
min_samples   = input.int(20,  "Min samples to display",  minval=1,                  group="Scout", tooltip="Below this, the cell shows n/a. Read nEff (independent), not n.")
lookback_bars = input.int(750, "Lookback window (bars)",  minval=50, maxval=10000,   group="Scout", tooltip="Rolling sample window. Signal and baseline share it.")
cal_len       = input.int(250, "Calibration burn-in (bars)", minval=30,              group="Scout", tooltip="Scout starts sampling after this many bars (percentile warm-up).")

// --- Overshoot ---
pct_len     = input.int(250,   "Overshoot percentile lookback",       minval=30,                       group="Overshoot")
pct_thresh  = input.float(90,  "Overshoot percentile threshold (%)",  minval=50, maxval=99.9, step=0.5, group="Overshoot")
pctl_basis  = input.string("Pooled", "Percentile basis", options=["Pooled", "By-direction"], group="Overshoot")
os_min_atr  = input.float(1.0, "Min overshoot (ATR)",                 minval=0.0,             step=0.1, group="Overshoot")
k_decontam  = input.int(3,     "Baseline exclude-recent (bars)",      minval=0,                        group="Overshoot")
dir_min     = input.int(30,    "By-direction min same-sign sample",   minval=10,                       group="Overshoot")

// --- Anchors ---
os_anchor = input.string("Regression", "Overshoot anchor", options=["Regression", "SMA", "EMA"], group="Anchors")
reg_len   = input.int(50,    "Anchor length",          minval=5, group="Anchors")
carry_basis = input.string("VWAP", "Carry baseline",     options=["VWAP", "SMA", "EMA"], group="Anchors")
carry_len   = input.int(50,     "Carry baseline length", minval=5, group="Anchors")
atr_len  = input.int(20, "ATR length (normalizer)", minval=2, group="Anchors")

// ===== Helper: arm/fire latch =====
f_arm_fire(extreme, revert, gate_valid, max_bars) =>
    var bool armed   = false
    var int  arm_bar = 0
    fire = false
    if armed and not gate_valid
        armed := false
    if armed and (bar_index - arm_bar) > max_bars
        armed := false
    if extreme
        armed   := true
        arm_bar := bar_index
    if armed and revert and not extreme
        fire := true
        armed := false
    fire

// ===== Helper: k-decontaminate a baseline series =====
f_decon(b, k) =>
    e = b[k]
    p = b[k + 1]
    e + (e - p) * k

// ===== Helper: linear-interpolation percentile of an array =====
f_pctile(arr, p) =>
    n = array.size(arr)
    float res = na
    if n >= 1
        s = array.copy(arr)
        array.sort(s, order.ascending)
        rank = (p / 100.0) * (n - 1)
        lo   = int(math.floor(rank))
        hi   = int(math.ceil(rank))
        frac = rank - lo
        res := array.get(s, lo) + frac * (array.get(s, hi) - array.get(s, lo))
    res

// ===== Helpers: scout =====
// Triple-barrier first-touch from the entry bar (which is fwd_bars back from `now`). Scans forward
// offsets fwd_bars-1 .. fwd_bars-tcap. Returns [outcome_ATR, hit(0 timeout/1 target/2 stop), mfe_ATR].
// Conservative: if both barriers fall in one bar, the STOP is assumed first.
f_barrier(is_long, entry, atr_sig) =>
    float tgt = is_long ? entry + bar_target_atr * atr_sig : entry - bar_target_atr * atr_sig
    float stp = is_long ? entry - bar_stop_atr   * atr_sig : entry + bar_stop_atr   * atr_sig
    int   cap = math.min(bar_tcap, fwd_bars)
    float out = na
    int   hitc = 0
    float mfe = 0.0
    for k = 1 to cap
        off = fwd_bars - k
        hi = high[off]
        lo = low[off]
        fav = is_long ? (hi - entry) / atr_sig : (entry - lo) / atr_sig
        mfe := math.max(mfe, fav)
        bool brk = false
        if is_long
            if lo <= stp
                out := -bar_stop_atr
                hitc := 2
                brk := true
            else if hi >= tgt
                out := bar_target_atr
                hitc := 1
                brk := true
        else
            if hi >= stp
                out := -bar_stop_atr
                hitc := 2
                brk := true
            else if lo <= tgt
                out := bar_target_atr
                hitc := 1
                brk := true
        if brk
            break
    if hitc == 0
        eoff = fwd_bars - cap
        out := is_long ? (close[eoff] - entry) / atr_sig : (entry - close[eoff]) / atr_sig
    [out, hitc, mfe]

f_push(bar_arr, out_arr, mfe_arr, hit_arr, out_v, mfe_v, hit_v) =>
    array.push(bar_arr, bar_index)
    array.push(out_arr, out_v)
    array.push(mfe_arr, mfe_v)
    array.push(hit_arr, hit_v)
    while array.size(bar_arr) > 0 and bar_index - array.first(bar_arr) > lookback_bars
        array.shift(bar_arr)
        array.shift(out_arr)
        array.shift(mfe_arr)
        array.shift(hit_arr)

// Effective n: non-overlapping samples (entries >= fwd_bars apart).
f_effn(bar_arr) =>
    n = array.size(bar_arr)
    cnt = 0
    int last = na
    if n > 0
        for i = 0 to n - 1
            b = array.get(bar_arr, i)
            if na(last) or b - last >= fwd_bars
                cnt += 1
                last := b
    cnt

// Edge (mean bucket - mean baseline) with SE from effective-n + dispersion. [edge, se, t, neff]
f_edge_se(sig, sig_bar, base, base_bar) =>
    ns = array.size(sig)
    nb = array.size(base)
    float edge = na
    float se   = na
    float t    = na
    int   es   = 0
    if ns >= min_samples and nb >= 1
        es := f_effn(sig_bar)
        eb = f_effn(base_bar)
        edge := array.avg(sig) - array.avg(base)
        vs = ns > 1 ? math.pow(array.stdev(sig), 2) : 0.0
        vb = nb > 1 ? math.pow(array.stdev(base), 2) : 0.0
        se := math.sqrt((es > 0 ? vs / es : 0.0) + (eb > 0 ? vb / eb : 0.0))
        t  := se > 0 ? edge / se : na
    [edge, se, t, es]

// Gate gap (mean Taken - mean Veto) with SE/t (baseline cancels). [gap, se, t]
f_gap(a, a_bar, b, b_bar) =>
    na_ = array.size(a)
    nb  = array.size(b)
    float gap = na
    float se  = na
    float t   = na
    if na_ >= min_samples and nb >= min_samples
        ea = f_effn(a_bar)
        eb = f_effn(b_bar)
        gap := array.avg(a) - array.avg(b)
        va = math.pow(array.stdev(a), 2)
        vb = math.pow(array.stdev(b), 2)
        se := math.sqrt((ea > 0 ? va / ea : 0.0) + (eb > 0 ? vb / eb : 0.0))
        t  := se > 0 ? gap / se : na
    [gap, se, t]

// First-touch rate for a hit code (1 target, 2 stop), as %.
f_rate(hit_arr, code) =>
    n = array.size(hit_arr)
    int c = 0
    if n > 0
        for i = 0 to n - 1
            if array.get(hit_arr, i) == code
                c += 1
    n > 0 ? 100.0 * c / n : na

f_mean_min(arr) => array.size(arr) >= min_samples ? array.avg(arr) : na
f_num_str(v) => na(v) ? "n/a" : (v > 0 ? "+" : "") + str.tostring(v, "#.00")
f_pct_str(v) => na(v) ? "-" : str.tostring(v, "#") + "%"
f_t_str(t)   => na(t) ? "n/a" : str.tostring(t, "#.0")
f_t_col(edge, t) => na(t) or math.abs(t) < 1.5 ? color.new(color.gray, 30) : edge > 0 ? color.new(#00C853, 0) : color.new(#FF1744, 0)

// ===== Components: overshoot engine =====
atr      = ta.atr(atr_len)
safe_atr = atr > 0 ? atr : na

reg_lr_end  = ta.linreg(close[k_decontam], reg_len, 0)
reg_lr_prev = ta.linreg(close[k_decontam], reg_len, 1)
reg_lr      = reg_lr_end + (reg_lr_end - reg_lr_prev) * k_decontam
reg_sma     = f_decon(ta.sma(close, reg_len), k_decontam)
reg_ema     = f_decon(ta.ema(close, reg_len), k_decontam)
reg         = os_anchor == "SMA" ? reg_sma : os_anchor == "EMA" ? reg_ema : reg_lr

atr_os = safe_atr[k_decontam]

sma_v      = ta.sma(close, carry_len)
ema_v      = ta.ema(close, carry_len)
vol_sum    = math.sum(volume, carry_len)
pv_sum     = math.sum(close * volume, carry_len)
rvwap      = vol_sum > 0 ? pv_sum / vol_sum : na
carry_base = carry_basis == "SMA" ? sma_v : carry_basis == "EMA" ? ema_v : rvwap

os = (na(atr_os) or na(reg))        ? na : (close - reg)      / atr_os
tc = (na(atr_os) or na(carry_base)) ? na : (reg - carry_base) / atr_os

// --- Extremity ---
os_pct  = ta.percentrank(os, pct_len)
os_p_hi_pool = ta.percentile_linear_interpolation(os, pct_len, pct_thresh)[k_decontam]
os_p_lo_pool = ta.percentile_linear_interpolation(os, pct_len, 100 - pct_thresh)[k_decontam]

var array<int>   os_w_bar = array.new<int>()
var array<float> os_w_val = array.new<float>()
if not na(os)
    array.push(os_w_bar, bar_index)
    array.push(os_w_val, os)
    while array.size(os_w_bar) > 0 and bar_index - array.first(os_w_bar) >= pct_len + k_decontam
        array.shift(os_w_bar)
        array.shift(os_w_val)

os_pos = array.new<float>()
os_neg = array.new<float>()
wn = array.size(os_w_val)
if pctl_basis == "By-direction" and wn > 0
    for i = 0 to wn - 1
        if bar_index - array.get(os_w_bar, i) >= k_decontam
            v = array.get(os_w_val, i)
            if v > 0
                array.push(os_pos, v)
            if v < 0
                array.push(os_neg, v)
os_p_hi_dir = array.size(os_pos) >= dir_min ? f_pctile(os_pos, pct_thresh)       : na
os_p_lo_dir = array.size(os_neg) >= dir_min ? f_pctile(os_neg, 100 - pct_thresh) : na

os_p_hi = pctl_basis == "By-direction" ? os_p_hi_dir : os_p_hi_pool
os_p_lo = pctl_basis == "By-direction" ? os_p_lo_dir : os_p_lo_pool

trig_up = math.max(os_min_atr,  nz(os_p_hi,  os_min_atr))
trig_dn = math.min(-os_min_atr, nz(os_p_lo, -os_min_atr))
os_ext_up  = not na(os) and os >= trig_up
os_ext_dn  = not na(os) and os <= trig_dn

bind_up_code = nz(os_p_hi, -1e9) >= os_min_atr  ? 1 : 0
bind_dn_code = nz(os_p_lo,  1e9) <= -os_min_atr ? 1 : 0

// ===== REGIME LAYER =====
er_den = math.sum(math.abs(close - close[1]), er_len)
er     = er_den > 0 ? math.abs(close - close[er_len]) / er_den : na

ret1 = close - close[1]
ac1  = ta.correlation(ret1, ret1[1], ac_len)    // READOUT ONLY
v1   = ta.variance(close - close[1],    vr_len)
vk   = ta.variance(close - close[vr_k], vr_len)
vr   = v1 > 0 ? vk / (vr_k * v1) : na            // READOUT ONLY

atr_pct   = ta.percentrank(atr, vol_pct_len)
vol_ma    = ta.sma(volume, vsma_len)
vol_surge = not na(vol_ma) and vol_ma > 0 and volume > vol_ma * vsurge_mult

slope_pb  = reg_lr_end - reg_lr_prev
slope_atr = (na(atr_os) or atr_os == 0) ? na : slope_pb / atr_os
dir_up    = not na(slope_atr) and slope_atr >  slope_dead_atr
dir_dn    = not na(slope_atr) and slope_atr < -slope_dead_atr

float er_exit_use = math.min(er_exit, er_trend)
var bool trend_on = false
trend_on := na(er) ? trend_on : (trend_on ? er >= er_exit_use : er >= er_trend)

cascade = not na(er) and er >= er_cascade and not na(atr_pct) and atr_pct >= vol_hi and vol_surge

int desired = cascade ? (dir_dn ? -2 : 2) : (trend_on and dir_up) ? 1 : (trend_on and dir_dn) ? -1 : 0

var int regime = 0
var int regime_dwell = 0
regime_dwell += 1
if cascade
    regime := desired
    regime_dwell := 0
else if desired != regime and regime_dwell >= regime_min_dwell
    regime := desired
    regime_dwell := 0

regime_allow_long  = regime == 0 or regime == 1
regime_allow_short = regime == 0 or regime == -1
allow_long_live    = regime_filter ? regime_allow_long  : true
allow_short_live   = regime_filter ? regime_allow_short : true

// ===== Fade signals =====
fade_up_raw = os_ext_up   // SHORT
fade_dn_raw = os_ext_dn   // LONG
fade_up_fire = f_arm_fire(fade_up_raw, not na(os) and not na(os[1]) and os < os[1], regime_allow_short, arm_max_bars)
fade_dn_fire = f_arm_fire(fade_dn_raw, not na(os) and not na(os[1]) and os > os[1], regime_allow_long,  arm_max_bars)
fade_up_sig = use_reversion ? fade_up_fire : fade_up_raw
fade_dn_sig = use_reversion ? fade_dn_fire : fade_dn_raw
fade_short = fade_up_sig and allow_short_live
fade_long  = fade_dn_sig and allow_long_live

// ===== Scout: triple-barrier outcomes, stratified Taken / Veto-DIR / Veto-CSC =====
// per bucket: entry bar, outcome (ATR), MFE (ATR), hit code (1 target / 2 stop / 0 timeout)
var array<int>   fl_t_bar  = array.new<int>()
var array<int>   fl_vd_bar = array.new<int>()
var array<int>   fl_vc_bar = array.new<int>()
var array<float> fl_t_out  = array.new<float>()
var array<float> fl_vd_out = array.new<float>()
var array<float> fl_vc_out = array.new<float>()
var array<float> fl_t_mfe  = array.new<float>()
var array<float> fl_vd_mfe = array.new<float>()
var array<float> fl_vc_mfe = array.new<float>()
var array<int>   fl_t_hit  = array.new<int>()
var array<int>   fl_vd_hit = array.new<int>()
var array<int>   fl_vc_hit = array.new<int>()
var array<int>   fs_t_bar  = array.new<int>()
var array<int>   fs_vd_bar = array.new<int>()
var array<int>   fs_vc_bar = array.new<int>()
var array<float> fs_t_out  = array.new<float>()
var array<float> fs_vd_out = array.new<float>()
var array<float> fs_vc_out = array.new<float>()
var array<float> fs_t_mfe  = array.new<float>()
var array<float> fs_vd_mfe = array.new<float>()
var array<float> fs_vc_mfe = array.new<float>()
var array<int>   fs_t_hit  = array.new<int>()
var array<int>   fs_vd_hit = array.new<int>()
var array<int>   fs_vc_hit = array.new<int>()
var array<int>   bs_bar    = array.new<int>()
var array<float> bl_out    = array.new<float>()
var array<float> bsh_out   = array.new<float>()

post_cal = bar_index - fwd_bars >= cal_len
if post_cal
    entry   = close[fwd_bars]
    atr_sig = safe_atr[fwd_bars]
    if not na(atr_sig) and atr_sig > 0 and not na(entry)
        [l_out, l_hit, l_mfe] = f_barrier(true,  entry, atr_sig)
        [s_out, s_hit, s_mfe] = f_barrier(false, entry, atr_sig)

        // Baseline = every bar, both perspectives (random-entry expectancy, same bracket).
        array.push(bs_bar, bar_index)
        array.push(bl_out, l_out)
        array.push(bsh_out, s_out)
        while array.size(bs_bar) > 0 and bar_index - array.first(bs_bar) > lookback_bars
            array.shift(bs_bar)
            array.shift(bl_out)
            array.shift(bsh_out)

        raw_long  = fade_dn_sig[fwd_bars]
        raw_short = fade_up_sig[fwd_bars]
        reg_sig   = regime[fwd_bars]
        long_ok   = reg_sig == 0 or reg_sig == 1
        short_ok  = reg_sig == 0 or reg_sig == -1
        is_casc   = math.abs(reg_sig) == 2
        if raw_long
            if long_ok
                f_push(fl_t_bar,  fl_t_out,  fl_t_mfe,  fl_t_hit,  l_out, l_mfe, l_hit)
            else if is_casc
                f_push(fl_vc_bar, fl_vc_out, fl_vc_mfe, fl_vc_hit, l_out, l_mfe, l_hit)
            else
                f_push(fl_vd_bar, fl_vd_out, fl_vd_mfe, fl_vd_hit, l_out, l_mfe, l_hit)
        if raw_short
            if short_ok
                f_push(fs_t_bar,  fs_t_out,  fs_t_mfe,  fs_t_hit,  s_out, s_mfe, s_hit)
            else if is_casc
                f_push(fs_vc_bar, fs_vc_out, fs_vc_mfe, fs_vc_hit, s_out, s_mfe, s_hit)
            else
                f_push(fs_vd_bar, fs_vd_out, fs_vd_mfe, fs_vd_hit, s_out, s_mfe, s_hit)

// ===== Colors =====
committed = barstate.isconfirmed
color st_col     = os_ext_up ? color.new(#FF1744, 0) : os_ext_dn ? color.new(#00C853, 0) : color.new(color.gray, 40)
color os_dir_col = os > 0 ? color.new(#26C6DA, 30) : os < 0 ? color.new(#FFA726, 30) : color.new(color.gray, 50)
color os_col     = os_color_mode == "Direction" ? os_dir_col : color.new(st_col, 30)
color tc_col     = color.new(#BB86FC, 0)

color reg_bg = na
if show_regime_bg
    reg_bg := regime ==  1 ? color.new(#00C853, 92) : regime == -1 ? color.new(#FF1744, 92) : (math.abs(regime) == 2 ? color.new(#FF6D00, 88) : color.new(color.gray, 96))
bgcolor(reg_bg, title="Regime tint")

// ===== Plots (oscillator pane) =====
plot(os,     "Overshoot (ATR)",            style=plot.style_columns, color=os_col)
plot(tc,     "Carry / displacement (ATR)", color=tc_col, linewidth=2)
plot(os_pct, "Overshoot percentile",       color=color.new(color.gray, 100), display=display.data_window)
plot(er,     "Efficiency Ratio",           color=color.new(color.gray, 100), display=display.data_window)
plot(ac1,    "Return autocorr (lag-1)",    color=color.new(color.gray, 100), display=display.data_window)
plot(vr,     "Variance ratio",             color=color.new(color.gray, 100), display=display.data_window)
plot(atr_pct,"Vol percentile",             color=color.new(color.gray, 100), display=display.data_window)
plot(regime, "Regime (0/+-1/+-2)",         color=color.new(color.gray, 100), display=display.data_window)
plot(os_p_hi,      "Pctile lvl + (pre-floor)", color=color.new(color.gray, 100), display=display.data_window)
plot(os_p_lo,      "Pctile lvl - (pre-floor)", color=color.new(color.gray, 100), display=display.data_window)
plot(bind_up_code, "Binding + (1=pctile,0=floor)", color=color.new(color.gray, 100), display=display.data_window)
plot(bind_dn_code, "Binding - (1=pctile,0=floor)", color=color.new(color.gray, 100), display=display.data_window)

pTrigUp = plot(trig_up, "Trigger + (fire level)", color=color.new(color.gray, 45), style=plot.style_stepline)
pTrigDn = plot(trig_dn, "Trigger - (fire level)", color=color.new(color.gray, 45), style=plot.style_stepline)
fill(pTrigUp, pTrigDn, color.new(color.gray, 92), "No-fire band")
hline(0, "Zero", color=color.new(color.gray, 0), linestyle=hline.style_solid)

// ===== Arrows on the PRICE pane =====
plotshape(show_turns and committed and fade_short ? high : na, "FADE SHORT", shape.triangledown, location.abovebar, color=color.new(#FF1744, 0), size=size.tiny, force_overlay=true)
plotshape(show_turns and committed and fade_long  ? low  : na, "FADE LONG",  shape.triangleup,   location.belowbar, color=color.new(#00C853, 0), size=size.tiny, force_overlay=true)
plotshape(show_turns and show_provisional and not committed and fade_short ? high : na, "FADE SHORT (prov)", shape.triangledown, location.abovebar, color=color.new(color.gray, 60), size=size.tiny, force_overlay=true)
plotshape(show_turns and show_provisional and not committed and fade_long  ? low  : na, "FADE LONG (prov)",  shape.triangleup,   location.belowbar, color=color.new(color.gray, 60), size=size.tiny, force_overlay=true)

// ===== State panel =====
string reg_label = regime == 1 ? "Trend-up (longs only)" : regime == -1 ? "Trend-down (shorts only)" : math.abs(regime) == 2 ? "CASCADE (stand aside)" : "Range (both)"
color  reg_bgc   = regime == 1 ? color.new(#00C853, 0) : regime == -1 ? color.new(#FF1744, 0) : math.abs(regime) == 2 ? color.new(#FF6D00, 0) : color.new(color.gray, 40)
string ext_label = os_ext_up ? "Up-extreme (SHORT)" : os_ext_dn ? "Down-extreme (LONG)" : "-"
color  ext_bg    = os_ext_up ? color.new(#FF1744, 0) : os_ext_dn ? color.new(#00C853, 0) : color.new(color.gray, 40)

var table panel = table.new(position.top_right, 2, 7, border_color=color.new(color.gray, 50), border_width=1, frame_color=color.new(color.gray, 50), frame_width=1)
if show_table and barstate.islast
    string forming = barstate.isconfirmed ? " (confirmed)" : " (forming)"
    table.cell(panel, 0, 0, "Regime",        text_color=color.silver, text_size=size.tiny)
    table.cell(panel, 1, 0, reg_label + (regime_filter ? "" : " [veto OFF]"), text_color=color.white, bgcolor=reg_bgc, text_size=size.tiny)
    table.cell(panel, 0, 1, "ER / AC1 / VR", text_color=color.silver, text_size=size.tiny)
    table.cell(panel, 1, 1, str.tostring(er, "#.00") + " / " + str.tostring(ac1, "#.00") + " / " + str.tostring(vr, "#.00"), text_color=color.white, text_size=size.tiny)
    table.cell(panel, 0, 2, "Vol pctile",    text_color=color.silver, text_size=size.tiny)
    table.cell(panel, 1, 2, str.tostring(atr_pct, "#.0") + " %" + (cascade ? "  SURGE" : ""), text_color=color.white, text_size=size.tiny)
    table.cell(panel, 0, 3, "Overshoot",     text_color=color.silver, text_size=size.tiny)
    table.cell(panel, 1, 3, str.tostring(os, "#.00") + " ATR", text_color=color.white, text_size=size.tiny)
    table.cell(panel, 0, 4, "Extremity",     text_color=color.silver, text_size=size.tiny)
    table.cell(panel, 1, 4, ext_label,       text_color=color.white, bgcolor=ext_bg, text_size=size.tiny)
    table.cell(panel, 0, 5, "Carry",         text_color=color.silver, text_size=size.tiny)
    table.cell(panel, 1, 5, str.tostring(tc, "#.00") + " ATR (" + carry_basis + ")", text_color=color.white, text_size=size.tiny)
    table.cell(panel, 0, 6, "Bracket",       text_color=color.silver, text_size=size.tiny)
    table.cell(panel, 1, 6, "+" + str.tostring(bar_target_atr, "#.0") + " / -" + str.tostring(bar_stop_atr, "#.0") + " / " + str.tostring(bar_tcap) + "b" + forming, text_color=color.white, text_size=size.tiny)

// ===== Scout dashboard (triple-barrier) =====
// Exp = mean(bucket outcome ATR) - mean(baseline). t from effective-n; colour only |t|>=1.5.
// Taken row Exp = GATE-0 (beats random entries?). "gate d" rows = Taken - Veto-DIR.
// tH%/sH% = target/stop first-touch rates. MFE = mean favorable excursion (front-loading tell).
var table scout = table.new(position.bottom_right, 7, 10, border_color=color.new(color.gray, 50), border_width=1, frame_color=color.new(color.gray, 50), frame_width=1)
bgsc = color.new(color.black, 50)

f_hdr(col, txt) => table.cell(scout, col, 0, txt, text_color=color.silver, bgcolor=bgsc, text_size=size.tiny)

f_row(r, lbl, out_arr, bar_arr, mfe_arr, hit_arr, base_out, base_bar, lblcol) =>
    [edge, se, t, neff] = f_edge_se(out_arr, bar_arr, base_out, base_bar)
    table.cell(scout, 0, r, lbl, text_color=lblcol, bgcolor=bgsc, text_size=size.tiny)
    table.cell(scout, 1, r, f_num_str(edge), text_color=color.white, bgcolor=f_t_col(edge, t), text_size=size.tiny)
    table.cell(scout, 2, r, f_t_str(t), text_color=color.white, text_size=size.tiny)
    table.cell(scout, 3, r, f_pct_str(f_rate(hit_arr, 1)), text_color=color.white, text_size=size.tiny)
    table.cell(scout, 4, r, f_pct_str(f_rate(hit_arr, 2)), text_color=color.silver, text_size=size.tiny)
    table.cell(scout, 5, r, f_num_str(f_mean_min(mfe_arr)), text_color=color.silver, text_size=size.tiny)
    table.cell(scout, 6, r, str.tostring(neff), text_color=color.white, text_size=size.tiny)

f_gate(r, lbl, t_out, t_bar, v_out, v_bar) =>
    [gap, se, tt] = f_gap(t_out, t_bar, v_out, v_bar)
    verdict = na(tt) ? "n/a" : tt >= 1.5 ? "EDGE" : tt <= -1.5 ? "ANTI" : "ns"
    table.cell(scout, 0, r, lbl, text_color=color.white, bgcolor=bgsc, text_size=size.tiny)
    table.cell(scout, 1, r, f_num_str(gap), text_color=color.white, bgcolor=f_t_col(gap, tt), text_size=size.tiny)
    table.cell(scout, 2, r, f_t_str(tt), text_color=color.white, text_size=size.tiny)
    table.cell(scout, 3, r, verdict, text_color=color.white, bgcolor=f_t_col(gap, tt), text_size=size.tiny)
    table.cell(scout, 4, r, "", text_color=color.silver, text_size=size.tiny)
    table.cell(scout, 5, r, "", text_color=color.silver, text_size=size.tiny)
    table.cell(scout, 6, r, "", text_color=color.silver, text_size=size.tiny)

if show_scout and barstate.islast
    f_hdr(0, "bucket")
    f_hdr(1, "Exp")
    f_hdr(2, "t")
    f_hdr(3, "tH%")
    f_hdr(4, "sH%")
    f_hdr(5, "MFE")
    f_hdr(6, "nEff")
    f_row(1, "L Taken",    fl_t_out,  fl_t_bar,  fl_t_mfe,  fl_t_hit,  bl_out,  bs_bar, color.silver)
    f_row(2, "L Veto-dir", fl_vd_out, fl_vd_bar, fl_vd_mfe, fl_vd_hit, bl_out,  bs_bar, color.gray)
    f_row(3, "L Veto-csc", fl_vc_out, fl_vc_bar, fl_vc_mfe, fl_vc_hit, bl_out,  bs_bar, color.gray)
    f_row(4, "S Taken",    fs_t_out,  fs_t_bar,  fs_t_mfe,  fs_t_hit,  bsh_out, bs_bar, color.silver)
    f_row(5, "S Veto-dir", fs_vd_out, fs_vd_bar, fs_vd_mfe, fs_vd_hit, bsh_out, bs_bar, color.gray)
    f_row(6, "S Veto-csc", fs_vc_out, fs_vc_bar, fs_vc_mfe, fs_vc_hit, bsh_out, bs_bar, color.gray)
    f_gate(7, "L gate d",  fl_t_out, fl_t_bar, fl_vd_out, fl_vd_bar)
    f_gate(8, "S gate d",  fs_t_out, fs_t_bar, fs_vd_out, fs_vd_bar)

// ===== Alerts (committed-only, regime-gated) =====
alertcondition(fade_short and committed, "FADE SHORT", "Overshoot extreme up, regime allows - fade short")
alertcondition(fade_long  and committed, "FADE LONG",  "Overshoot extreme down, regime allows - fade long")

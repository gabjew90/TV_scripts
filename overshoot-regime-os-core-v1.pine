//@version=6
indicator("Jamal Phase 1 v8", shorttitle="Jamal P1v8", overlay=false)

// =====================================================================
// CONDITIONER-DISCOVERY INSTRUMENT (advisor reframe).
//
// Stop asserting "trend = ER>0.30" and hoping it separates fade outcomes. Instead measure,
// per overshoot signal, the forward ASYMMETRY  A = MFE - MAE  (bracket-free, ATR, full window)
// against pre-committed candidate CONDITIONERS, and let outcome-separation DEFINE the regime
// variable. The label becomes an output you discover, not an input you defend.
//
// Per conditioner the dashboard reports: winsorized (fat-tail-robust) correlation r(C, A) with
// effective-n t, plus a tercile mean-A table (shape check). A conditioner is REAL only if:
//   significant |t| AND monotone across the 3 bins AND correctly signed by its mechanism AND
//   it replicates across symbols/TFs. Otherwise -> no regime carves the fade here -> fade is dead
//   (this instrument is equally a clean KILL TEST).
//
// Correlation (every signal, one number) not more buckets (binning shreds nEff). Winsorized
// Pearson, not raw Pearson (one liquidation candle manufactures a correlation). Tercile table is
// a SHAPE check only: monotone slope = real; all signal in one bin = outlier artifact.
//
// PRE-COMMITTED CONDITIONERS (4, each with a mechanism — anti-HARK):
//   C1 signed-efficiency = ER * sign(os) * sign(slope): counter-trend overshoots inside a strong
//      trend bounce hardest (one-sided positioning -> squeeze); with-trend ones continue. [v4 lead]
//   C2 |overshoot|      : depth past the trigger — does a deeper extreme revert more?
//   C3 velocity         = |os - os[vel_len]|: violent spike vs slow grind into the extreme.
//   C4 |carry| = |tc|   : trend's displacement from VWAP at signal, as a reversion conditioner.
//
// BOUNDED TO TRADINGVIEW. NOT a backtest; descriptive, cost-blind, overlapping. Regime state
// machine retained only for the tint/context (C1 uses ER+slope directly, not the discrete label).
// =====================================================================

// ===== Inputs =====
// --- Regime (context + provides ER/slope/tc for conditioners) ---
regime_filter   = input.bool(true,  "Apply regime veto (live plot only)", group="Regime")
er_len          = input.int(20,   "Efficiency Ratio length",      minval=5,                         group="Regime")
er_trend        = input.float(0.30, "ER trend ENTER threshold",    minval=0.05, maxval=0.95, step=0.01, group="Regime")
er_exit         = input.float(0.18, "ER trend EXIT threshold",     minval=0.01, maxval=0.95, step=0.01, group="Regime")
regime_min_dwell = input.int(3,   "Regime minimum dwell (bars)",  minval=1,                         group="Regime")
ac_len          = input.int(50,   "Autocorr length (lag-1) [READOUT]", minval=10,                   group="Regime")
vr_k            = input.int(5,    "Variance-ratio horizon k [READOUT]", minval=2,                   group="Regime")
vr_len          = input.int(50,   "Variance-ratio sample length [READOUT]", minval=20,              group="Regime")
vol_pct_len     = input.int(250,  "Vol percentile lookback",      minval=50,                        group="Regime")
vol_hi          = input.float(80,   "Vol-hot percentile (cascade)", minval=50, maxval=99, step=1,     group="Regime")
er_cascade      = input.float(0.45, "ER cascade threshold",        minval=0.3, maxval=0.99, step=0.01, group="Regime")
vsma_len        = input.int(20,   "Volume MA length (surge)",     minval=5,                         group="Regime")
vsurge_mult     = input.float(1.8,  "Volume surge multiple",        minval=1.0, step=0.1,             group="Regime")
slope_dead_atr  = input.float(0.05, "Trend slope deadband (ATR/bar)", minval=0.0, step=0.01,         group="Regime")

// --- Arrows ---
use_reversion = input.bool(false, "Fire on reversion (1 per episode)", group="Arrows")
arm_max_bars  = input.int(24, "Reversion arm timeout (bars)", minval=1, group="Arrows")

// --- Display ---
show_turns       = input.bool(true,  "Show fade arrows on price", group="Display")
show_provisional = input.bool(true,  "Show provisional (forming-bar) signals", group="Display")
show_table       = input.bool(true,  "Show state panel (top-right)", group="Display")
show_scout       = input.bool(true,  "Show conditioner dashboard (bottom-right)", group="Display")
show_regime_bg   = input.bool(true,  "Tint pane by regime", group="Display")
os_color_mode    = input.string("State", "Overshoot column color", options=["State", "Direction"], group="Display")

// --- Scout / conditioner instrument ---
fwd_bars      = input.int(12,  "Excursion window (bars)",   minval=2,                group="Scout", tooltip="Horizon over which MFE/MAE (and A=MFE-MAE) are measured; also the effective-n independence spacing.")
vel_len       = input.int(3,   "Velocity lookback (bars)",  minval=1,                group="Scout", tooltip="C3 velocity = |os - os[vel_len]| at signal time.")
min_samples   = input.int(20,  "Min samples to display",  minval=1,                  group="Scout")
lookback_bars = input.int(1500, "Lookback window (bars)", minval=50, maxval=10000,   group="Scout")
cal_len       = input.int(250, "Calibration burn-in (bars)", minval=30,              group="Scout")

// --- Overshoot ---
pct_len     = input.int(250,   "Overshoot percentile lookback",       minval=30,                       group="Overshoot")
pct_thresh  = input.float(90,  "Overshoot percentile threshold (%)",  minval=50, maxval=99.9, step=0.5, group="Overshoot")
pctl_basis  = input.string("Pooled", "Percentile basis", options=["Pooled", "By-direction"], group="Overshoot")
os_min_atr  = input.float(1.0, "Min overshoot (ATR)",                 minval=0.0,             step=0.1, group="Overshoot")
k_decontam  = input.int(3,     "Baseline exclude-recent (bars)",      minval=0,                        group="Overshoot")
dir_min     = input.int(30,    "By-direction min same-sign sample",   minval=10,                       group="Overshoot")

// --- Anchors ---
os_anchor = input.string("Regression", "Overshoot anchor", options=["Regression", "SMA", "EMA"], group="Anchors")
reg_len   = input.int(50,    "Anchor length",          minval=5, group="Anchors")
carry_basis = input.string("VWAP", "Carry baseline",     options=["VWAP", "SMA", "EMA"], group="Anchors")
carry_len   = input.int(50,     "Carry baseline length", minval=5, group="Anchors")
atr_len  = input.int(20, "ATR length (normalizer)", minval=2, group="Anchors")

// --- Scout (appended last to keep input IDs stable hereafter) ---
min_eff = input.int(8, "Min effective-n (gate floor)", minval=1, group="Scout")

// ===== Helper: arm/fire latch =====
f_arm_fire(extreme, revert, gate_valid, max_bars) =>
    var bool armed   = false
    var int  arm_bar = 0
    fire = false
    if armed and not gate_valid
        armed := false
    if armed and (bar_index - arm_bar) > max_bars
        armed := false
    if extreme
        armed   := true
        arm_bar := bar_index
    if armed and revert and not extreme
        fire := true
        armed := false
    fire

// ===== Helper: k-decontaminate a baseline series =====
f_decon(b, k) =>
    e = b[k]
    p = b[k + 1]
    e + (e - p) * k

// ===== Helper: linear-interpolation percentile of an array =====
f_pctile(arr, p) =>
    n = array.size(arr)
    float res = na
    if n >= 1
        s = array.copy(arr)
        array.sort(s, order.ascending)
        rank = (p / 100.0) * (n - 1)
        lo   = int(math.floor(rank))
        hi   = int(math.ceil(rank))
        frac = rank - lo
        res := array.get(s, lo) + frac * (array.get(s, hi) - array.get(s, lo))
    res

// ===== Helpers: conditioner instrument =====
f_clip(v, lo, hi) => math.max(lo, math.min(hi, v))

// Full-window MFE/MAE (bracket-free) from the entry bar (fwd_bars back). [mfe_ATR, mae_ATR]
f_excursion(is_long, entry, atr_sig) =>
    float mfe = 0.0
    float mae = 0.0
    for k = 1 to fwd_bars
        off = fwd_bars - k
        hi = high[off]
        lo = low[off]
        fav = is_long ? (hi - entry) / atr_sig : (entry - lo) / atr_sig
        adv = is_long ? (entry - lo) / atr_sig : (hi - entry) / atr_sig
        mfe := math.max(mfe, fav)
        mae := math.max(mae, adv)
    [mfe, mae]

f_cpush(bar_a, a_a, c1_a, c2_a, c3_a, c4_a, av, c1v, c2v, c3v, c4v) =>
    array.push(bar_a, bar_index)
    array.push(a_a, av)
    array.push(c1_a, c1v)
    array.push(c2_a, c2v)
    array.push(c3_a, c3v)
    array.push(c4_a, c4v)
    while array.size(bar_a) > 0 and bar_index - array.first(bar_a) > lookback_bars
        array.shift(bar_a)
        array.shift(a_a)
        array.shift(c1_a)
        array.shift(c2_a)
        array.shift(c3_a)
        array.shift(c4_a)

// Effective n: non-overlapping signals spaced by the excursion window (outcome resolution horizon).
f_effn(bar_arr) =>
    n = array.size(bar_arr)
    cnt = 0
    int last = na
    if n > 0
        for i = 0 to n - 1
            b = array.get(bar_arr, i)
            if na(last) or b - last >= fwd_bars
                cnt += 1
                last := b
    cnt

// Winsorized (5/95) Pearson correlation of c vs a — fat-tail robust, O(n). na if n < min_samples.
f_wins_corr(c, a) =>
    n = array.size(c)
    float r = na
    if n >= min_samples
        cl = f_pctile(c, 5)
        ch = f_pctile(c, 95)
        al = f_pctile(a, 5)
        ah = f_pctile(a, 95)
        float mc = 0.0
        float ma = 0.0
        for i = 0 to n - 1
            mc += f_clip(array.get(c, i), cl, ch)
            ma += f_clip(array.get(a, i), al, ah)
        mc := mc / n
        ma := ma / n
        float num = 0.0
        float dc  = 0.0
        float da  = 0.0
        for i = 0 to n - 1
            cc = f_clip(array.get(c, i), cl, ch) - mc
            aa = f_clip(array.get(a, i), al, ah) - ma
            num += cc * aa
            dc  += cc * cc
            da  += aa * aa
        r := (dc > 0 and da > 0) ? num / math.sqrt(dc * da) : na
    r

f_corr_t(r, neff) => (na(r) or neff < 3) ? na : r * math.sqrt(math.max(neff - 2, 0) / math.max(1 - r * r, 0.000001))

// Tercile mean-A (winsorized A) by C bin -> [lo, mid, hi]. Shape check for monotonicity.
f_bins(c, a) =>
    n = array.size(c)
    float m0 = na
    float m1 = na
    float m2 = na
    if n >= min_samples
        e1 = f_pctile(c, 33.33333)
        e2 = f_pctile(c, 66.66667)
        al = f_pctile(a, 5)
        ah = f_pctile(a, 95)
        float s0 = 0.0
        float s1 = 0.0
        float s2 = 0.0
        int k0 = 0
        int k1 = 0
        int k2 = 0
        for i = 0 to n - 1
            ci = array.get(c, i)
            ai = f_clip(array.get(a, i), al, ah)
            if ci < e1
                s0 += ai
                k0 += 1
            else if ci < e2
                s1 += ai
                k1 += 1
            else
                s2 += ai
                k2 += 1
        m0 := k0 > 0 ? s0 / k0 : na
        m1 := k1 > 0 ? s1 / k1 : na
        m2 := k2 > 0 ? s2 / k2 : na
    [m0, m1, m2]

f_num_str(v) => na(v) ? "n/a" : (v > 0 ? "+" : "") + str.tostring(v, "#.00")
f_t_str(t)   => na(t) ? "n/a" : str.tostring(t, "#.0")
f_t_col(v, t) => na(t) or math.abs(t) < 2.0 ? color.new(color.gray, 30) : v > 0 ? color.new(#00C853, 0) : color.new(#FF1744, 0)

// ===== Components: overshoot engine =====
atr      = ta.atr(atr_len)
safe_atr = atr > 0 ? atr : na

reg_lr_end  = ta.linreg(close[k_decontam], reg_len, 0)
reg_lr_prev = ta.linreg(close[k_decontam], reg_len, 1)
reg_lr      = reg_lr_end + (reg_lr_end - reg_lr_prev) * k_decontam
reg_sma     = f_decon(ta.sma(close, reg_len), k_decontam)
reg_ema     = f_decon(ta.ema(close, reg_len), k_decontam)
reg         = os_anchor == "SMA" ? reg_sma : os_anchor == "EMA" ? reg_ema : reg_lr

atr_os = safe_atr[k_decontam]

sma_v      = ta.sma(close, carry_len)
ema_v      = ta.ema(close, carry_len)
vol_sum    = math.sum(volume, carry_len)
pv_sum     = math.sum(close * volume, carry_len)
rvwap      = vol_sum > 0 ? pv_sum / vol_sum : na
carry_base = carry_basis == "SMA" ? sma_v : carry_basis == "EMA" ? ema_v : rvwap

os = (na(atr_os) or na(reg))        ? na : (close - reg)      / atr_os
tc = (na(atr_os) or na(carry_base)) ? na : (reg - carry_base) / atr_os
os_vel = os - os[vel_len]

// --- Extremity ---
os_pct  = ta.percentrank(os, pct_len)
os_p_hi_pool = ta.percentile_linear_interpolation(os, pct_len, pct_thresh)[k_decontam]
os_p_lo_pool = ta.percentile_linear_interpolation(os, pct_len, 100 - pct_thresh)[k_decontam]

var array<int>   os_w_bar = array.new<int>()
var array<float> os_w_val = array.new<float>()
if not na(os)
    array.push(os_w_bar, bar_index)
    array.push(os_w_val, os)
    while array.size(os_w_bar) > 0 and bar_index - array.first(os_w_bar) >= pct_len + k_decontam
        array.shift(os_w_bar)
        array.shift(os_w_val)

os_pos = array.new<float>()
os_neg = array.new<float>()
wn = array.size(os_w_val)
if pctl_basis == "By-direction" and wn > 0
    for i = 0 to wn - 1
        if bar_index - array.get(os_w_bar, i) >= k_decontam
            v = array.get(os_w_val, i)
            if v > 0
                array.push(os_pos, v)
            if v < 0
                array.push(os_neg, v)
os_p_hi_dir = array.size(os_pos) >= dir_min ? f_pctile(os_pos, pct_thresh)       : na
os_p_lo_dir = array.size(os_neg) >= dir_min ? f_pctile(os_neg, 100 - pct_thresh) : na

os_p_hi = pctl_basis == "By-direction" ? os_p_hi_dir : os_p_hi_pool
os_p_lo = pctl_basis == "By-direction" ? os_p_lo_dir : os_p_lo_pool

trig_up = math.max(os_min_atr,  nz(os_p_hi,  os_min_atr))
trig_dn = math.min(-os_min_atr, nz(os_p_lo, -os_min_atr))
os_ext_up  = not na(os) and os >= trig_up
os_ext_dn  = not na(os) and os <= trig_dn

bind_up_code = nz(os_p_hi, -1e9) >= os_min_atr  ? 1 : 0
bind_dn_code = nz(os_p_lo,  1e9) <= -os_min_atr ? 1 : 0

// ===== REGIME LAYER (context + ER/slope for C1) =====
er_den = math.sum(math.abs(close - close[1]), er_len)
er     = er_den > 0 ? math.abs(close - close[er_len]) / er_den : na

ret1 = close - close[1]
ac1  = ta.correlation(ret1, ret1[1], ac_len)    // READOUT ONLY
v1   = ta.variance(close - close[1],    vr_len)
vk   = ta.variance(close - close[vr_k], vr_len)
vr   = v1 > 0 ? vk / (vr_k * v1) : na            // READOUT ONLY

atr_pct   = ta.percentrank(atr, vol_pct_len)
vol_ma    = ta.sma(volume, vsma_len)
vol_surge = not na(vol_ma) and vol_ma > 0 and volume > vol_ma * vsurge_mult

slope_pb  = reg_lr_end - reg_lr_prev
slope_atr = (na(atr_os) or atr_os == 0) ? na : slope_pb / atr_os
dir_up    = not na(slope_atr) and slope_atr >  slope_dead_atr
dir_dn    = not na(slope_atr) and slope_atr < -slope_dead_atr

float er_exit_use = math.min(er_exit, er_trend)
var bool trend_on = false
trend_on := na(er) ? trend_on : (trend_on ? er >= er_exit_use : er >= er_trend)

cascade = not na(er) and er >= er_cascade and not na(atr_pct) and atr_pct >= vol_hi and vol_surge

int desired = cascade ? (dir_dn ? -2 : 2) : (trend_on and dir_up) ? 1 : (trend_on and dir_dn) ? -1 : 0

var int regime = 0
var int regime_dwell = 0
regime_dwell += 1
if cascade
    regime := desired
    regime_dwell := 0
else if desired != regime and regime_dwell >= regime_min_dwell
    regime := desired
    regime_dwell := 0

regime_allow_long  = regime == 0 or regime == 1
regime_allow_short = regime == 0 or regime == -1
allow_long_live    = regime_filter ? regime_allow_long  : true
allow_short_live   = regime_filter ? regime_allow_short : true

// ===== Fade signals =====
fade_up_raw = os_ext_up
fade_dn_raw = os_ext_dn
fade_up_fire = f_arm_fire(fade_up_raw, not na(os) and not na(os[1]) and os < os[1], regime_allow_short, arm_max_bars)
fade_dn_fire = f_arm_fire(fade_dn_raw, not na(os) and not na(os[1]) and os > os[1], regime_allow_long,  arm_max_bars)
fade_up_sig = use_reversion ? fade_up_fire : fade_up_raw
fade_dn_sig = use_reversion ? fade_dn_fire : fade_dn_raw
fade_short = fade_up_sig and allow_short_live
fade_long  = fade_dn_sig and allow_long_live

// ===== Conditioner instrument: per signal, record A and C1..C4 (sampled at SIGNAL time) =====
var array<int>   c_bar = array.new<int>()
var array<float> c_a   = array.new<float>()
var array<float> c_c1  = array.new<float>()
var array<float> c_c2  = array.new<float>()
var array<float> c_c3  = array.new<float>()
var array<float> c_c4  = array.new<float>()

post_cal = bar_index - fwd_bars >= cal_len
if post_cal
    entry   = close[fwd_bars]
    atr_sig = safe_atr[fwd_bars]
    sig_long  = fade_dn_sig[fwd_bars]   // down-extreme -> fade long
    sig_short = fade_up_sig[fwd_bars]   // up-extreme   -> fade short
    if (sig_long or sig_short) and not na(atr_sig) and atr_sig > 0 and not na(entry)
        [mfe, mae] = f_excursion(sig_long, entry, atr_sig)
        a   = mfe - mae
        os_s  = os[fwd_bars]
        sl_s  = slope_atr[fwd_bars]
        er_s  = er[fwd_bars]
        tc_s  = tc[fwd_bars]
        vel_s = os_vel[fwd_bars]
        float c1 = (na(er_s) or na(sl_s) or na(os_s)) ? na : er_s * math.sign(os_s) * math.sign(sl_s)
        float c2 = na(os_s)  ? na : math.abs(os_s)
        float c3 = na(vel_s) ? na : math.abs(vel_s)
        float c4 = na(tc_s)  ? na : math.abs(tc_s)
        if not na(a) and not na(c1) and not na(c2) and not na(c3) and not na(c4)
            f_cpush(c_bar, c_a, c_c1, c_c2, c_c3, c_c4, a, c1, c2, c3, c4)

// ===== Colors =====
committed = barstate.isconfirmed
color st_col     = os_ext_up ? color.new(#FF1744, 0) : os_ext_dn ? color.new(#00C853, 0) : color.new(color.gray, 40)
color os_dir_col = os > 0 ? color.new(#26C6DA, 30) : os < 0 ? color.new(#FFA726, 30) : color.new(color.gray, 50)
color os_col     = os_color_mode == "Direction" ? os_dir_col : color.new(st_col, 30)
color tc_col     = color.new(#BB86FC, 0)

color reg_bg = na
if show_regime_bg
    reg_bg := regime ==  1 ? color.new(#00C853, 92) : regime == -1 ? color.new(#FF1744, 92) : (math.abs(regime) == 2 ? color.new(#FF6D00, 88) : color.new(color.gray, 96))
bgcolor(reg_bg, title="Regime tint")

// ===== Plots (oscillator pane) =====
plot(os,     "Overshoot (ATR)",            style=plot.style_columns, color=os_col)
plot(tc,     "Carry / displacement (ATR)", color=tc_col, linewidth=2)
plot(os_pct, "Overshoot percentile",       color=color.new(color.gray, 100), display=display.data_window)
plot(er,     "Efficiency Ratio",           color=color.new(color.gray, 100), display=display.data_window)
plot(ac1,    "Return autocorr (lag-1)",    color=color.new(color.gray, 100), display=display.data_window)
plot(vr,     "Variance ratio",             color=color.new(color.gray, 100), display=display.data_window)
plot(atr_pct,"Vol percentile",             color=color.new(color.gray, 100), display=display.data_window)
plot(regime, "Regime (0/+-1/+-2)",         color=color.new(color.gray, 100), display=display.data_window)
plot(os_vel, "Overshoot velocity",         color=color.new(color.gray, 100), display=display.data_window)

pTrigUp = plot(trig_up, "Trigger + (fire level)", color=color.new(color.gray, 45), style=plot.style_stepline)
pTrigDn = plot(trig_dn, "Trigger - (fire level)", color=color.new(color.gray, 45), style=plot.style_stepline)
fill(pTrigUp, pTrigDn, color.new(color.gray, 92), "No-fire band")
hline(0, "Zero", color=color.new(color.gray, 0), linestyle=hline.style_solid)

// ===== Arrows on the PRICE pane =====
plotshape(show_turns and committed and fade_short ? high : na, "FADE SHORT", shape.triangledown, location.abovebar, color=color.new(#FF1744, 0), size=size.tiny, force_overlay=true)
plotshape(show_turns and committed and fade_long  ? low  : na, "FADE LONG",  shape.triangleup,   location.belowbar, color=color.new(#00C853, 0), size=size.tiny, force_overlay=true)
plotshape(show_turns and show_provisional and not committed and fade_short ? high : na, "FADE SHORT (prov)", shape.triangledown, location.abovebar, color=color.new(color.gray, 60), size=size.tiny, force_overlay=true)
plotshape(show_turns and show_provisional and not committed and fade_long  ? low  : na, "FADE LONG (prov)",  shape.triangleup,   location.belowbar, color=color.new(color.gray, 60), size=size.tiny, force_overlay=true)

// ===== State panel =====
string reg_label = regime == 1 ? "Trend-up" : regime == -1 ? "Trend-down" : math.abs(regime) == 2 ? "CASCADE" : "Range"
color  reg_bgc   = regime == 1 ? color.new(#00C853, 0) : regime == -1 ? color.new(#FF1744, 0) : math.abs(regime) == 2 ? color.new(#FF6D00, 0) : color.new(color.gray, 40)
string ext_label = os_ext_up ? "Up-extreme (SHORT)" : os_ext_dn ? "Down-extreme (LONG)" : "-"
color  ext_bg    = os_ext_up ? color.new(#FF1744, 0) : os_ext_dn ? color.new(#00C853, 0) : color.new(color.gray, 40)

var table panel = table.new(position.top_right, 2, 7, border_color=color.new(color.gray, 50), border_width=1, frame_color=color.new(color.gray, 50), frame_width=1)
if show_table and barstate.islast
    string forming = barstate.isconfirmed ? " (confirmed)" : " (forming)"
    table.cell(panel, 0, 0, "Regime",        text_color=color.silver, text_size=size.tiny)
    table.cell(panel, 1, 0, reg_label,       text_color=color.white, bgcolor=reg_bgc, text_size=size.tiny)
    table.cell(panel, 0, 1, "ER / AC1 / VR", text_color=color.silver, text_size=size.tiny)
    table.cell(panel, 1, 1, str.tostring(er, "#.00") + " / " + str.tostring(ac1, "#.00") + " / " + str.tostring(vr, "#.00"), text_color=color.white, text_size=size.tiny)
    table.cell(panel, 0, 2, "Vol pctile",    text_color=color.silver, text_size=size.tiny)
    table.cell(panel, 1, 2, str.tostring(atr_pct, "#.0") + " %", text_color=color.white, text_size=size.tiny)
    table.cell(panel, 0, 3, "Overshoot",     text_color=color.silver, text_size=size.tiny)
    table.cell(panel, 1, 3, str.tostring(os, "#.00") + " ATR", text_color=color.white, text_size=size.tiny)
    table.cell(panel, 0, 4, "Extremity",     text_color=color.silver, text_size=size.tiny)
    table.cell(panel, 1, 4, ext_label,       text_color=color.white, bgcolor=ext_bg, text_size=size.tiny)
    table.cell(panel, 0, 5, "Carry",         text_color=color.silver, text_size=size.tiny)
    table.cell(panel, 1, 5, str.tostring(tc, "#.00") + " ATR (" + carry_basis + ")", text_color=color.white, text_size=size.tiny)
    table.cell(panel, 0, 6, "Window/sig",    text_color=color.silver, text_size=size.tiny)
    table.cell(panel, 1, 6, str.tostring(fwd_bars) + "b / n=" + str.tostring(array.size(c_a)) + forming, text_color=color.white, text_size=size.tiny)

// ===== Conditioner dashboard =====
// r = winsorized corr(C, A); A = MFE-MAE (fade asymmetry, ATR). t from effective-n; colour |t|>=2.
// A.lo/mid/hi = tercile mean-A (shape: monotone = real conditioner, one hot bin = artifact).
// REAL conditioner = significant t + monotone bins + correct sign + cross-symbol replication.
var table scout = table.new(position.bottom_right, 7, 6, border_color=color.new(color.gray, 50), border_width=1, frame_color=color.new(color.gray, 50), frame_width=1)
bgsc = color.new(color.black, 50)

f_crow(r, lbl, carr, aarr, barr) =>
    rr = f_wins_corr(carr, aarr)
    nef = f_effn(barr)
    tt = nef >= min_eff ? f_corr_t(rr, nef) : na
    [m0, m1, m2] = f_bins(carr, aarr)
    table.cell(scout, 0, r, lbl, text_color=color.silver, bgcolor=bgsc, text_size=size.tiny)
    table.cell(scout, 1, r, na(tt) ? "n/a" : f_num_str(rr), text_color=color.white, bgcolor=f_t_col(rr, tt), text_size=size.tiny)
    table.cell(scout, 2, r, f_t_str(tt), text_color=color.white, text_size=size.tiny)
    table.cell(scout, 3, r, f_num_str(m0), text_color=color.silver, text_size=size.tiny)
    table.cell(scout, 4, r, f_num_str(m1), text_color=color.silver, text_size=size.tiny)
    table.cell(scout, 5, r, f_num_str(m2), text_color=color.silver, text_size=size.tiny)
    table.cell(scout, 6, r, str.tostring(nef), text_color=color.white, text_size=size.tiny)

if show_scout and barstate.islast
    table.cell(scout, 0, 0, "C\\A n=" + str.tostring(array.size(c_a)), text_color=color.silver, bgcolor=bgsc, text_size=size.tiny)
    table.cell(scout, 1, 0, "r",     text_color=color.silver, bgcolor=bgsc, text_size=size.tiny)
    table.cell(scout, 2, 0, "t",     text_color=color.silver, bgcolor=bgsc, text_size=size.tiny)
    table.cell(scout, 3, 0, "A.lo",  text_color=color.silver, bgcolor=bgsc, text_size=size.tiny)
    table.cell(scout, 4, 0, "A.mid", text_color=color.silver, bgcolor=bgsc, text_size=size.tiny)
    table.cell(scout, 5, 0, "A.hi",  text_color=color.silver, bgcolor=bgsc, text_size=size.tiny)
    table.cell(scout, 6, 0, "nEff",  text_color=color.silver, bgcolor=bgsc, text_size=size.tiny)
    f_crow(1, "C1 SignEff", c_c1, c_a, c_bar)
    f_crow(2, "C2 |OS|",    c_c2, c_a, c_bar)
    f_crow(3, "C3 Veloc",   c_c3, c_a, c_bar)
    f_crow(4, "C4 |Carry|", c_c4, c_a, c_bar)

// ===== Alerts (committed-only, regime-gated) =====
alertcondition(fade_short and committed, "FADE SHORT", "Overshoot extreme up, regime allows - fade short")
alertcondition(fade_long  and committed, "FADE LONG",  "Overshoot extreme down, regime allows - fade long")

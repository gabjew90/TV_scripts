//@version=6
// Phase 2 H2 DATA-INTEGRITY + DISTRIBUTION GATE for LIQUIDATIONS (standing gate, liq variant).
// Liquidations are an UNSIGNED, EPISODIC series (legitimately ~0 on quiet bars) -> the signed
// "positive series -> forward-return" leak fingerprint used for funding does NOT apply directly.
// What we must verify before trusting H2:
//   (1) COVERAGE / history depth (full window, both Buy & Sell).
//   (2) NO FORWARD-FILL of a spike: longest run of an identical repeated nonzero value (staleness).
//   (3) MECHANISTIC SANITY (not a leak, a sanity check): sell-liq dominant bars should be RED,
//       buy-liq dominant bars GREEN (same-bar). High match = cascades cause the move (expected),
//       NOT lookahead — we only ever USE lagged liq in the harness, so within-bar timing is moot.
//   (4) TAIL / nEff: the H2 signal is large flushes. Report magnitude pctile cuts + how many bars
//       sit in the top decile, and the EFFECTIVE n of top-decile flushes spaced >= fwd_bars apart.
// Edit fwd_bars to match the H2 instrument's forward horizon.
indicator("P2 liq gate", overlay=false)
import TradingView/Request/3 as r

fwd_bars = input.int(12, "fwd horizon (for nEff spacing)")
cal_len  = input.int(250, "calib window (bars) for pctile")

liq_buy  = r.cryptoDerivativeMetric(metricName = "Liquidations Buy",  symbol = syminfo.tickerid, timeframe = timeframe.period)
liq_sell = r.cryptoDerivativeMetric(metricName = "Liquidations Sell", symbol = syminfo.tickerid, timeframe = timeframe.period)
mag      = (na(liq_buy) ? 0.0 : liq_buy) + (na(liq_sell) ? 0.0 : liq_sell)
netliq   = (na(liq_sell) ? 0.0 : liq_sell) - (na(liq_buy) ? 0.0 : liq_buy)   // >0 = sell-liq dominant (downward push)

// (1) coverage
var int nBars = 0
var int nBuyNZ = 0
var int nSellNZ = 0
var int nMagNZ = 0
nBars += 1
if not na(liq_buy)  and liq_buy  > 0
    nBuyNZ  += 1
if not na(liq_sell) and liq_sell > 0
    nSellNZ += 1
if mag > 0
    nMagNZ += 1

// (2) forward-fill / staleness: longest run of identical NONZERO mag + LOCALIZATION
recent_win = input.int(2250, "recent H2-sample window (bars from end)")
var int curRun = 0
var int maxRun = 0
var int maxRunEndBar = 0       // bar_index where the longest run ended
var int nRunsGt5 = 0           // count of distinct stale runs (>5 identical)
var int nStaleBarsRecent = 0   // bars inside a stale run (>5) within the recent window
if mag > 0 and mag == mag[1]
    curRun += 1
else
    if curRun > 5
        nRunsGt5 += 1          // a run just ended; count it once
    curRun := 0
if curRun > maxRun
    maxRun := curRun
    maxRunEndBar := bar_index
// recent-window stale tally: any bar currently extending a >5 run, counted if near the end
isStaleNow = curRun > 5
isRecent   = (last_bar_index - bar_index) <= recent_win
if isStaleNow and isRecent
    nStaleBarsRecent += 1

// (3) mechanistic sanity: sign(netliq) vs same-bar return sign (only on bars with real imbalance)
ret0 = close - open
var int nImb = 0
var int nConcord = 0
if math.abs(netliq) > 0 and mag > 0
    nImb += 1
    // sell-liq dominant (netliq>0) should pair with a DOWN bar (ret0<0); buy-liq with UP
    if (netliq > 0 and ret0 < 0) or (netliq < 0 and ret0 > 0)
        nConcord += 1

// (4) tail / nEff of top-decile flushes
p50 = ta.percentile_linear_interpolation(mag, cal_len, 50)
p90 = ta.percentile_linear_interpolation(mag, cal_len, 90)
p99 = ta.percentile_linear_interpolation(mag, cal_len, 99)
var float magMax = 0.0
magMax := math.max(magMax, mag)

// effective n of top-decile flushes spaced >= fwd_bars apart
var int   nTop = 0
var int   nTopEff = 0
var int   lastTopBar = -1000000
isTop = bar_index > cal_len and not na(p90) and mag >= p90 and mag > 0
if isTop
    nTop += 1
    if bar_index - lastTopBar >= fwd_bars
        nTopEff += 1
        lastTopBar := bar_index

covBuy  = nBars > 0 ? 100.0 * nBuyNZ  / nBars : na
covSell = nBars > 0 ? 100.0 * nSellNZ / nBars : na
covMag  = nBars > 0 ? 100.0 * nMagNZ  / nBars : na
concord = nImb  > 0 ? 100.0 * nConcord / nImb  : na

maxRunBarsAgo = last_bar_index - maxRunEndBar
var table t = table.new(position.top_left, 2, 14, border_color=color.gray, border_width=1, frame_color=color.gray, frame_width=1)
if barstate.islast
    table.cell(t,0,0,"LIQ gate",text_color=color.silver), table.cell(t,1,0,"value",text_color=color.silver)
    table.cell(t,0,1,"total bars",text_color=color.silver), table.cell(t,1,1,str.tostring(nBars),text_color=color.white)
    table.cell(t,0,2,"% bars Buy>0",text_color=color.silver), table.cell(t,1,2,str.tostring(covBuy,"#.#")+"%",text_color=covBuy>0?color.lime:color.red)
    table.cell(t,0,3,"% bars Sell>0",text_color=color.silver), table.cell(t,1,3,str.tostring(covSell,"#.#")+"%",text_color=covSell>0?color.lime:color.red)
    table.cell(t,0,4,"% bars mag>0",text_color=color.silver), table.cell(t,1,4,str.tostring(covMag,"#.#")+"%",text_color=covMag>0?color.lime:color.red)
    table.cell(t,0,5,"max identical-mag run",text_color=color.silver), table.cell(t,1,5,str.tostring(maxRun),text_color=maxRun>3?color.red:color.lime)
    table.cell(t,0,6,"  ^ ended bars-ago",text_color=color.silver), table.cell(t,1,6,str.tostring(maxRunBarsAgo),text_color=maxRunBarsAgo<=recent_win?color.red:color.lime)
    table.cell(t,0,7,"# stale runs (>5)",text_color=color.silver), table.cell(t,1,7,str.tostring(nRunsGt5),text_color=nRunsGt5>0?color.orange:color.lime)
    table.cell(t,0,8,"stale bars in recent win",text_color=color.silver), table.cell(t,1,8,str.tostring(nStaleBarsRecent),text_color=nStaleBarsRecent>0?color.red:color.lime)
    table.cell(t,0,9,"sign(netliq)~bar concord %",text_color=color.silver), table.cell(t,1,9,str.tostring(concord,"#.#")+"%",text_color=color.white)
    table.cell(t,0,10,"mag p50 / p90 / p99",text_color=color.silver), table.cell(t,1,10,str.tostring(p50,"#.#")+" / "+str.tostring(p90,"#.#")+" / "+str.tostring(p99,"#.#"),text_color=color.white)
    table.cell(t,0,11,"mag max",text_color=color.silver), table.cell(t,1,11,str.tostring(magMax,"#.#"),text_color=color.white)
    table.cell(t,0,12,"top-decile flushes n",text_color=color.silver), table.cell(t,1,12,str.tostring(nTop),text_color=color.white)
    table.cell(t,0,13,"top-decile nEff (spaced)",text_color=color.silver), table.cell(t,1,13,str.tostring(nTopEff),text_color=nTopEff>=20?color.lime:(nTopEff>=8?color.orange:color.red))

plot(na)

//@version=6
indicator("Jamal OB v0.33.0", shorttitle = "JOB0.33", overlay = true, max_boxes_count = 50)

// ════════════════ Identity ════════════════
SCRIPT_V = "0.33.0"

// ════════════════ Inputs ════════════════
max_lookback = input.int(200, "Walk-back max lookback (bars)", minval = 10)
start_ts     = input.time(timestamp("1 Jul 2023 00:00 +0000"), "State start date",
     tooltip = "The OB state machine ignores all bars before this date: no sweeps fire and walk-backs clamp here. Default = ~3 years back; symbols younger than that simply start at their first bar. Caps how stale a line can be. NOTE: if a device loads less history than this (e.g. mobile), the lines can differ across devices — tighten the date if that matters.")

// ════════════════ Vocabulary (v0.33.0) ════════════════
// ORIGIN  — the candle that starts the down series; its open is the line.
// TRIGGER — any candle that fires a walk-back. Three trigger events, ALWAYS
//           armed (no established/search states, no resets — all removed):
//             1. BOTTOM SWEEP — price trades below the current series' lowest
//                low (the guard). Intrabar; this is the lower-low chain.
//             2. PIVOT SWEEP — a red candle takes out the most recent
//                CONFIRMED 3-candle swing low. One-shot per swing (a swept
//                swing is consumed once a placement succeeds off it).
//             3. FVG SWEEP — the first later candle to enter a bull gap
//                (one-shot per zone; a zone cannot be swept by the candle
//                that creates it — v0.28.0).
// BOTTOM  — the walked series' lowest low; stored as the GUARD. Sweeping the
//           guard (not the Trigger candle's own wick — v0.33.0 placement
//           guard fix) is what makes the next candle a new Trigger.
// The line is simply the walk-back of the most recent Trigger: it moves ONLY
// when a new Trigger fires, and only if the walk-back finds a real down-series
// behind it (else the line holds). Bear side is the exact high↔low mirror.

// ════════════════ Bullish walk-back (lower line = Origin's open) ════════════════
// From the anchor bar at offset s0 (the Trigger candle if it is RED; the bar
// BEFORE it if the Trigger is green), walk backward over the contiguous
// down-leg. Returns [open_R, leg_lo]:
//   open_R = highest red open in the leg (the Origin's open = the line; when
//            the anchor is red it may be the anchor's own open),
//   leg_lo = lowest low over [stop-candle .. s0] (the series BOTTOM → guard).
// v0.17.0 3-CANDLE STOP rule (16-permutation table + inside-candle edge-case
// pass; real legs VVV / SOL 8h / SOL 1W): reds are in-leg (running max of red
// opens). At a GREEN counter G with OLDER neighbour L (bar i+1) and NEWER
// neighbour R (bar i-1, toward the Trigger):
//   STOP iff  G.high > L.high  OR  ( R.high > G.high  AND  G.low is NOT between
//   L.low and R.low ) — R rises above G while G's low sits OUTSIDE the L–R low
//   band (i.e. R ENGULFS G, or G is a swing low). Else PAUSE, keep walking.
// v0.29.0: a FLAT doji (close == open) follows the same rule as a green.
f_walkback_bull(int maxlb, int s0, int t0) =>
    float best_open = close[s0] < open[s0] ? open[s0] : na   // seed R only if anchor bar is red
    float leg_lo    = low[s0]
    for i = s0 + 1 to s0 + maxlb
        if time[i] < t0
            break                                   // determinism clamp: never walk before the start date
        leg_lo := math.min(leg_lo, low[i])          // series BOTTOM includes every scanned bar, incl. the stop-candle
        if close[i] < open[i]                        // red → in leg
            best_open := na(best_open) ? open[i] : math.max(best_open, open[i])
            continue
        bool a_hi = high[i] > high[i + 1]            // G.high > L.high (older)
        bool b_hi = high[i] > high[i - 1]            // G.high > R.high (newer)
        bool c_lo = low[i]  > low[i + 1]             // G.low  > L.low
        bool d_lo = low[i]  > low[i - 1]             // G.low  > R.low
        if close[i] >= open[i] and not a_hi and (b_hi or (c_lo != d_lo))
            continue                                // green/doji pass-through: not a local top; pokes above R OR its low is BETWEEN the two lows → keep walking
        break                                       // green/doji STOPS: local top (high>L), OR R above it with its low OUTSIDE the L–R low band (R engulfs / swing low)
    [best_open, leg_lo]

// ════════════════ Bearish walk-back (upper line = Origin's open) ════════════════
// Mirror: anchor at s0 (the Trigger candle if GREEN; the bar before if red).
// Returns [open_R, leg_hi]: open_R = lowest green open (supply line);
// leg_hi = highest high over [stop-candle .. s0] (the series TOP → guard).
// v0.17.0 3-CANDLE STOP rule — EXACT MIRROR of the bull side (high↔low).
// v0.29.0: a FLAT doji follows the same rule as the red counter.
f_walkback_bear(int maxlb, int s0, int t0) =>
    float best_open = close[s0] > open[s0] ? open[s0] : na   // seed R only if anchor bar is green
    float leg_hi    = high[s0]
    for i = s0 + 1 to s0 + maxlb
        if time[i] < t0
            break                                   // determinism clamp: never walk before the start date
        leg_hi := math.max(leg_hi, high[i])         // series TOP includes every scanned bar, incl. the stop-candle
        if close[i] > open[i]                        // green → in leg
            best_open := na(best_open) ? open[i] : math.min(best_open, open[i])
            continue
        bool a_lo = low[i]  < low[i + 1]             // RED.low < L.low (older)
        bool b_lo = low[i]  < low[i - 1]             // RED.low < R.low (newer)
        bool c_hi = high[i] < high[i + 1]            // RED.high < L.high
        bool d_hi = high[i] < high[i - 1]            // RED.high < R.high
        if close[i] <= open[i] and not a_lo and (b_lo or (c_hi != d_hi))
            continue                                // red/doji pass-through: not a local bottom; R drops below it OR its high is BETWEEN the two highs → keep walking
        break                                       // red/doji STOPS: local bottom (low<L), OR R below it with high OUTSIDE the L–R high band (R engulfs / swing high)
    [best_open, leg_hi]

// ════════════════ State ════════════════
bool active = time >= start_ts                       // machine is dead before the start date

var float lower_line    = na
var float upper_line    = na
var float bull_guard_lo = na       // the series BOTTOM from the last placement — trading below it = new Trigger (chain)
var float bear_guard_hi = na       // the series TOP — trading above it = new Trigger
var bool  bull_touched      = false   // level retested from above (latched until reloc; colour only)
var bool  bull_closed_above = false   // level reclaimed (armed; colour only)
var bool  bear_touched      = false
var bool  bear_closed_below = false
var array<box>  bull_fvg_boxes = array.new<box>()    // light-green support gaps (feed the FVG-sweep trigger)
var array<bool> bull_fvg_mit   = array.new<bool>()   // parallel — has box[i] been swept (capped, no longer extends)?
var array<box>  bear_fvg_boxes = array.new<box>()    // light-red resistance gaps
var array<bool> bear_fvg_mit   = array.new<bool>()

// ════════════════ FVG zones (chart TF) — last 5 FORMED per side, shaded fill only; a swept zone is CAPPED at the sweeping candle (kept, not deleted) ════════════════
// v0.28.0: MITIGATION RUNS BEFORE DETECTION — a zone cannot be swept by the
// candle that CREATES it; the sweep is the first LATER candle to enter it.
// v0.32.0: detection lands on the PATTERN'S OWN COMPLETING CLOSE — the
// confirmed bar itself is the third candle (`low > high[2]` / `high < low[2]`).
// Same gap, same boundaries, zero-repaint (the block is close-gated). (The
// 4-TF DW latch below keeps the old [1]/[3] offsets — un-gated, display only.)
bool bull_fvg_touched = false          // price FIRST entered a bull FVG this bar → FVG-sweep Trigger (fires once per zone)
bool bear_fvg_touched = false
if barstate.isconfirmed and active
    if array.size(bull_fvg_boxes) > 0   // sweep check FIRST: on the first touch (low ≤ zone top) cap the box at this candle + stop extending
        for i = 0 to array.size(bull_fvg_boxes) - 1
            box b = array.get(bull_fvg_boxes, i)
            if not array.get(bull_fvg_mit, i) and low <= box.get_top(b)
                box.set_right(b, bar_index)
                box.set_extend(b, extend.none)
                array.set(bull_fvg_mit, i, true)
                bull_fvg_touched := true
    if array.size(bear_fvg_boxes) > 0
        for i = 0 to array.size(bear_fvg_boxes) - 1
            box b = array.get(bear_fvg_boxes, i)
            if not array.get(bear_fvg_mit, i) and high >= box.get_bottom(b)
                box.set_right(b, bar_index)
                box.set_extend(b, extend.none)
                array.set(bear_fvg_mit, i, true)
                bear_fvg_touched := true
    if low > high[2]                    // THEN detect at THIS confirmed close: new bull FVG [high[2] .. low] — untouchable until the next bar
        array.push(bull_fvg_boxes, box.new(bar_index - 1, low, bar_index, high[2], border_width = 0, bgcolor = color.new(color.green, 78), extend = extend.right))
        array.push(bull_fvg_mit, false)
        if array.size(bull_fvg_boxes) > 5   // keep only the last 5 FORMED (swept ones still count)
            box.delete(array.shift(bull_fvg_boxes))
            array.shift(bull_fvg_mit)
    if high < low[2]                    // new bear FVG [high .. low[2]]
        array.push(bear_fvg_boxes, box.new(bar_index - 1, low[2], bar_index, high, border_width = 0, bgcolor = color.new(color.red, 78), extend = extend.right))
        array.push(bear_fvg_mit, false)
        if array.size(bear_fvg_boxes) > 5
            box.delete(array.shift(bear_fvg_boxes))
            array.shift(bear_fvg_mit)

// ════════════════ Bullish (lower / demand) — v0.33.0 stateless Trigger model ════════════════
// Three always-armed Triggers (see Vocabulary). Any of them → walk-back from
// the Trigger candle (or the bar before, if it is the wrong colour to seed the
// leg) → the line moves to the Origin's open — ONLY if the walk finds a real
// down-series behind the entry (else the line holds). The GUARD becomes the
// walked series' BOTTOM (min of the leg's lows and the Trigger candle's own
// low) — v0.33.0: no more hollow re-Triggers off the old Trigger's wick.
var float bull_swing_low   = na        // most recent confirmed 3-candle swing low (pivot-sweep reference)
var bool  bull_swing_swept = false     // one-shot: a swing is consumed once a placement succeeds off it
bool bull_prev_touched = bull_touched  // colour only
bool bull_wick  = active and not na(bull_guard_lo) and low < bull_guard_lo   // Trigger 1: BOTTOM sweep (intrabar chain)
bool bull_pivot = active and barstate.isconfirmed and not bull_swing_swept and close < open and not na(bull_swing_low) and low < bull_swing_low   // Trigger 2: PIVOT sweep
if barstate.isconfirmed and low[1] < low[2] and low[1] < low and time[1] >= start_ts
    bull_swing_low   := low[1]         // updated AFTER the pivot check (the Trigger reads the incoming swing state)
    bull_swing_swept := false
bool bull_reloc = active and (bull_wick or bull_pivot or bull_fvg_touched)   // Trigger 3: FVG sweep
bool bull_did_reloc = false
if bull_reloc
    int s0b = close < open ? 0 : 1
    [oRb, wlo] = f_walkback_bull(max_lookback, s0b, start_ts)
    if not na(oRb)                     // eligible only if the walk-back finds a real demand (a down-series behind the entry)
        lower_line    := oRb
        bull_guard_lo := math.min(low, wlo)
        bull_did_reloc := true
if bull_pivot and bull_did_reloc
    bull_swing_swept := true           // consume the swing only when a placement actually happened (v0.28 lesson)

// ════════════════ Bearish (upper / supply) — EXACT MIRROR ════════════════
var float bear_swing_high   = na       // most recent confirmed 3-candle swing high (pivot-sweep reference)
var bool  bear_swing_swept  = false
bool bear_prev_touched = bear_touched  // colour only
bool bear_wick  = active and not na(bear_guard_hi) and high > bear_guard_hi   // Trigger 1: TOP sweep (intrabar chain)
bool bear_pivot = active and barstate.isconfirmed and not bear_swing_swept and close > open and not na(bear_swing_high) and high > bear_swing_high   // Trigger 2: PIVOT sweep
if barstate.isconfirmed and high[1] > high[2] and high[1] > high and time[1] >= start_ts
    bear_swing_high  := high[1]        // updated AFTER the pivot check
    bear_swing_swept := false
bool bear_reloc = active and (bear_wick or bear_pivot or bear_fvg_touched)    // Trigger 3: FVG sweep
bool bear_did_reloc = false
if bear_reloc
    int s0s = close > open ? 0 : 1
    [oRs, whi] = f_walkback_bear(max_lookback, s0s, start_ts)
    if not na(oRs)                     // eligible only if the walk-back finds a real supply (an up-series behind the entry)
        upper_line    := oRs
        bear_guard_hi := math.max(high, whi)
        bear_did_reloc := true
if bear_pivot and bear_did_reloc
    bear_swing_swept := true

// ════════════════ Line freshness (render state) ════════════════
// BRIGHT = reclaimed and not retested since. Green: arms when a bar AFTER the
// setting bar CONFIRMS a close above the line (the arming bar's pass-through
// wick doesn't count, nor do pre-reclaim wicks from below). Once armed, the
// first low back at the line latches "touched" → dull until relocation (no
// re-arm). The FIRST touch bar itself stays bright (colour reads the prior
// bar's touched state). Red: exact mirror.
if bull_did_reloc
    bull_touched      := false
    bull_closed_above := false
else if not na(lower_line)
    if bull_closed_above and low <= lower_line
        bull_touched := true
    else if not bull_touched and barstate.isconfirmed and close > lower_line
        bull_closed_above := true

if bear_did_reloc
    bear_touched      := false
    bear_closed_below := false
else if not na(upper_line)
    if bear_closed_below and high >= upper_line
        bear_touched := true
    else if not bear_touched and barstate.isconfirmed and close < upper_line
        bear_closed_below := true

bool  bull_bright = bull_closed_above and not bull_prev_touched
bool  bear_bright = bear_closed_below and not bear_prev_touched
color lower_col   = bull_bright ? color.new(color.green, 0) : color.new(color.green, 60)
color upper_col   = bear_bright ? color.new(color.red, 0)   : color.new(color.red, 60)

// ════════════════ FVG identification (v0.7.0 — state only, NOT drawn) ════════════════
// 3-candle fair value gap latches for the Data Window, four timeframes (chart
// TF + D / W / M via request.security with internal [1..3] offsets +
// lookahead_on — the standard non-repaint idiom). The latch lives INSIDE the
// function (per-security-context var state). NOTE: the DRAWN boxes above
// detect one bar earlier (at the pattern's own completing close) — this latch
// keeps the lagged offsets because it is not close-gated. Display only.
f_fvg_latest() =>
    var float bb = na    // latest bull gap bot / top
    var float bt = na
    var float sb = na    // latest bear gap bot / top
    var float st = na
    if low[1] > high[3]
        bb := high[3]
        bt := low[1]
    if high[1] < low[3]
        sb := high[1]
        st := low[3]
    [bb, bt, sb, st]

[fvg_c_bull_bot, fvg_c_bull_top, fvg_c_bear_bot, fvg_c_bear_top] = f_fvg_latest()
[fvg_d_bull_bot, fvg_d_bull_top, fvg_d_bear_bot, fvg_d_bear_top] = request.security(syminfo.tickerid, "D", f_fvg_latest(), lookahead = barmerge.lookahead_on)
[fvg_w_bull_bot, fvg_w_bull_top, fvg_w_bear_bot, fvg_w_bear_top] = request.security(syminfo.tickerid, "W", f_fvg_latest(), lookahead = barmerge.lookahead_on)
[fvg_m_bull_bot, fvg_m_bull_top, fvg_m_bear_bot, fvg_m_bear_top] = request.security(syminfo.tickerid, "M", f_fvg_latest(), lookahead = barmerge.lookahead_on)

// ════════════════ Render ════════════════
plot(lower_line, "OB lower (demand — Origin's open)", lower_col, 2, plot.style_stepline)
plot(upper_line, "OB upper (supply — Origin's open)", upper_col, 2, plot.style_stepline)
plot(bull_bright ? 1 : 0, "DW lower fresh (1=bright)", display = display.data_window)
plot(bear_bright ? 1 : 0, "DW upper fresh (1=bright)", display = display.data_window)
plot(bull_guard_lo, "DW lower guard (series bottom)", display = display.data_window)
plot(bear_guard_hi, "DW upper guard (series top)", display = display.data_window)
plot(fvg_c_bull_top, "DW FVG chart bull top", display = display.data_window)
plot(fvg_c_bull_bot, "DW FVG chart bull bot", display = display.data_window)
plot(fvg_c_bear_top, "DW FVG chart bear top", display = display.data_window)
plot(fvg_c_bear_bot, "DW FVG chart bear bot", display = display.data_window)
plot(fvg_d_bull_top, "DW FVG D bull top", display = display.data_window)
plot(fvg_d_bull_bot, "DW FVG D bull bot", display = display.data_window)
plot(fvg_d_bear_top, "DW FVG D bear top", display = display.data_window)
plot(fvg_d_bear_bot, "DW FVG D bear bot", display = display.data_window)
plot(fvg_w_bull_top, "DW FVG W bull top", display = display.data_window)
plot(fvg_w_bull_bot, "DW FVG W bull bot", display = display.data_window)
plot(fvg_w_bear_top, "DW FVG W bear top", display = display.data_window)
plot(fvg_w_bear_bot, "DW FVG W bear bot", display = display.data_window)
plot(fvg_m_bull_top, "DW FVG M bull top", display = display.data_window)
plot(fvg_m_bull_bot, "DW FVG M bull bot", display = display.data_window)
plot(fvg_m_bear_top, "DW FVG M bear top", display = display.data_window)
plot(fvg_m_bear_bot, "DW FVG M bear bot", display = display.data_window)

// ════════════════ Version tag ════════════════
var table vt = table.new(position.top_right, 1, 1)
if barstate.islast
    table.cell(vt, 0, 0, "Jamal OB v" + SCRIPT_V, text_color = color.white, bgcolor = color.new(color.black, 20))

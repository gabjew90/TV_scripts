//@version=6
indicator("Jamal OB v0.2.2", shorttitle = "JOB0.2.2", overlay = true)

// ════════════════ Identity ════════════════
SCRIPT_V = "0.2.2"

// ════════════════ Inputs ════════════════
max_lookback     = input.int(200,    "Walk-back max lookback (bars)", minval = 10)
hold_until_swept = input.bool(false, "Hold OB until its low/high is swept (sticky)")

// ════════════════ Bullish walk-back (lower line = open_R) ════════════════
// From the anchor bar at offset s0 (the sweep candle if it is RED; the bar
// BEFORE it if the sweep candle is green), walk backward over the contiguous
// down-leg. Returns [open_R, leg_hi]:
//   open_R = highest red open in the leg (the demand line level; when the
//            anchor is red it may be the anchor's own open),
//   leg_hi = swing high over [stop-candle .. s0] (the bullish BOS / structure
//            level whose close-through resets a sticky OB).
// Termination is STRUCTURE-ONLY (green-that-held / doji); a mid-leg green pause
// (bar toward the anchor made a new low AND this green didn't break out up) is
// skipped. The running max selects R; it never stops the walk.
f_walkback_bull(int maxlb, int s0) =>
    float best_open = close[s0] < open[s0] ? open[s0] : na   // seed R only if anchor bar is red
    float leg_hi    = high[s0]
    for i = s0 + 1 to s0 + maxlb
        leg_hi := math.max(leg_hi, high[i])
        if close[i] < open[i]                       // red → in leg
            best_open := na(best_open) ? open[i] : math.max(best_open, open[i])
            continue
        if close[i] > open[i]                       // green → pause or stop
            if low[i - 1] < low[i] and high[i] <= high[i + 1]
                continue                            // mid-leg pause: skip
        break                                       // green-that-held or doji → stop
    [best_open, leg_hi]

// ════════════════ Bearish walk-back (upper line = open_R) ════════════════
// Mirror: anchor at s0 (the sweep candle if GREEN; the bar before if red).
// Returns [open_R, leg_lo]: open_R = lowest green open (supply line);
// leg_lo = swing low over [stop-candle .. s0] (bearish BOS level).
f_walkback_bear(int maxlb, int s0) =>
    float best_open = close[s0] > open[s0] ? open[s0] : na   // seed R only if anchor bar is green
    float leg_lo    = low[s0]
    for i = s0 + 1 to s0 + maxlb
        leg_lo := math.min(leg_lo, low[i])
        if close[i] > open[i]                       // green → in leg
            best_open := na(best_open) ? open[i] : math.min(best_open, open[i])
            continue
        if close[i] < open[i]                       // red → pause or stop
            if high[i - 1] > high[i] and low[i] >= low[i + 1]
                continue                            // mid-leg pause: skip
        break                                       // red-that-held or doji → stop
    [best_open, leg_lo]

// ════════════════ Sweep triggers + line state ════════════════
// Default (hold_until_swept = false): every same-side sweep re-anchors the
// line — the v0.1 behavior, confirmed-bar gated (no repaint). Sticky (true):
// the line LOCKS at the current OB and relocates only when (a) its anchor
// low/high is wicked out, or (b) after a structure break (close beyond the leg
// origin `*_bos`) the next sweep forms a fresh OB. A green bullish anchor (red
// bearish anchor) starts its walk-back one bar earlier (s0 = 1).
//
// The (a) WICK sweep fires INTRABAR — the moment the forming bar's low/high
// breaks the anchor — so it relocates live. It repaints on the forming bar but
// is identical to the confirmed result once the bar closes (the wick is already
// in the bar's final low/high), so all CLOSED-bar history is unchanged. The
// colour-based triggers (bootstrap / post-break new sweep / default mode) stay
// confirmed-gated since they must know the candle is red/green.
bool bull_sweep = close < open and low  < low[1]    // red, new low
bool bear_sweep = close > open and high > high[1]    // green, new high

var float lower_line       = na
var float upper_line       = na
var float bull_anchor_low  = na    // low of the sweep candle currently holding lower_line
var float bull_bos         = na    // bullish structure level (down-leg origin)
var bool  bull_broken      = false // has price closed above bull_bos since anchoring?
var float bear_anchor_high = na
var float bear_bos         = na
var bool  bear_broken      = false

// Bullish (lower / demand)
if barstate.isconfirmed and hold_until_swept and not na(bull_bos) and close > bull_bos
    bull_broken := true
bool bull_wick = hold_until_swept and not na(bull_anchor_low) and low < bull_anchor_low          // intrabar
bool bull_conf = barstate.isconfirmed and (hold_until_swept ? (na(bull_anchor_low) ? bull_sweep : (bull_broken and bull_sweep)) : bull_sweep)
if bull_wick or bull_conf
    int s0b = close < open ? 0 : 1
    [oRb, swb] = f_walkback_bull(max_lookback, s0b)
    lower_line      := oRb
    bull_anchor_low := low
    bull_bos        := swb
    bull_broken     := false

// Bearish (upper / supply)
if barstate.isconfirmed and hold_until_swept and not na(bear_bos) and close < bear_bos
    bear_broken := true
bool bear_wick = hold_until_swept and not na(bear_anchor_high) and high > bear_anchor_high        // intrabar
bool bear_conf = barstate.isconfirmed and (hold_until_swept ? (na(bear_anchor_high) ? bear_sweep : (bear_broken and bear_sweep)) : bear_sweep)
if bear_wick or bear_conf
    int s0s = close > open ? 0 : 1
    [oRs, sws] = f_walkback_bear(max_lookback, s0s)
    upper_line       := oRs
    bear_anchor_high := high
    bear_bos         := sws
    bear_broken      := false

// ════════════════ Demand-line freshness (render state only) ════════════════
// The green line is BRIGHT only once (a) a bar AFTER the one that set the line
// has CONFIRMED a close above it, AND (b) the level is UNTOUCHED — no later
// bar's low has come back to the level. On relocation both flags reset, so a
// fresh line always starts DULL (the reloc bar's own close doesn't count, and
// its low is below open_R by construction). A touch dims it until relocation.
var bool bull_touched      = false
var bool bull_closed_above = false
if bull_wick or bull_conf
    bull_touched      := false
    bull_closed_above := false
else if not na(lower_line)
    if low <= lower_line
        bull_touched := true
    if barstate.isconfirmed and close > lower_line
        bull_closed_above := true
color lower_col = bull_closed_above and not bull_touched ? color.new(color.green, 0) : color.new(color.green, 60)

// ════════════════ Render ════════════════
plot(lower_line, "OB lower (demand open_R)", lower_col, 2, plot.style_stepline)
plot(upper_line, "OB upper (supply open_R)", color.red, 2, plot.style_stepline)

// ════════════════ Version tag ════════════════
var table vt = table.new(position.top_right, 1, 1)
if barstate.islast
    table.cell(vt, 0, 0, "Jamal OB v" + SCRIPT_V, text_color = color.white, bgcolor = color.new(color.black, 20))

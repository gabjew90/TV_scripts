//@version=6
indicator("Jamal OB v0.6.0", shorttitle = "JOB0.6.0", overlay = true)

// ════════════════ Identity ════════════════
SCRIPT_V = "0.6.0"

// ════════════════ Inputs ════════════════
max_lookback = input.int(200, "Walk-back max lookback (bars)", minval = 10)
start_ts     = input.time(timestamp("1 Jul 2025 00:00 +0000"), "State start date",
     tooltip = "The OB state machine ignores all bars before this date: no sweeps fire and walk-backs clamp here. Makes the lines DETERMINISTIC across devices (otherwise they depend on how much history the chart loads) and caps how stale a line can be.")

// ════════════════ Bullish walk-back (lower line = open_R) ════════════════
// From the anchor bar at offset s0 (the sweep candle if it is RED; the bar
// BEFORE it if the sweep candle is green), walk backward over the contiguous
// down-leg. Returns [open_R, leg_hi]:
//   open_R = highest red open in the leg (the demand line level; when the
//            anchor is red it may be the anchor's own open),
//   leg_hi = swing high over [stop-candle .. s0] (the leg-origin / BOS level:
//            a close through it re-enables sweep-driven relocation).
// Termination is STRUCTURE-ONLY (green-that-held / doji). v0.6.0: a green
// "held" only if NO bar later in the leg (toward the anchor) ever traded below
// its low — judged against the leg's running low (`lo_seen`), not just the
// single next bar (the old one-bar test read a deep mid-leg wick as a hold).
// A pausing green must also not have broken out up vs the earlier bar. The
// running max of red opens selects R; it never stops the walk.
f_walkback_bull(int maxlb, int s0, int t0) =>
    float best_open = close[s0] < open[s0] ? open[s0] : na   // seed R only if anchor bar is red
    float leg_hi    = high[s0]
    float lo_seen   = low[s0]                       // lowest low of bars already in the leg
    for i = s0 + 1 to s0 + maxlb
        if time[i] < t0
            break                                   // determinism clamp: never walk before the start date
        bool is_red      = close[i] < open[i]
        bool green_pause = close[i] > open[i] and lo_seen < low[i] and high[i] <= high[i + 1]
        leg_hi  := math.max(leg_hi, high[i])        // BOS extreme includes every scanned bar, incl. the stop-candle
        lo_seen := math.min(lo_seen, low[i])
        if is_red                                   // red → in leg
            best_open := na(best_open) ? open[i] : math.max(best_open, open[i])
            continue
        if green_pause
            continue                                // mid-leg pause: skip
        break                                       // green-that-held or doji → stop
    [best_open, leg_hi]

// ════════════════ Bearish walk-back (upper line = open_R) ════════════════
// Mirror: anchor at s0 (the sweep candle if GREEN; the bar before if red).
// Returns [open_R, leg_lo]: open_R = lowest green open (supply line);
// leg_lo = swing low over [stop-candle .. s0] (bearish BOS level).
// (v0.6.0 mirror: a red "held" only if no later bar in the leg ever traded
// above its high — judged against the leg's running high `hi_seen`.)
f_walkback_bear(int maxlb, int s0, int t0) =>
    float best_open = close[s0] > open[s0] ? open[s0] : na   // seed R only if anchor bar is green
    float leg_lo    = low[s0]
    float hi_seen   = high[s0]                      // highest high of bars already in the leg
    for i = s0 + 1 to s0 + maxlb
        if time[i] < t0
            break                                   // determinism clamp: never walk before the start date
        bool is_green  = close[i] > open[i]
        bool red_pause = close[i] < open[i] and hi_seen > high[i] and low[i] >= low[i + 1]
        leg_lo  := math.min(leg_lo, low[i])         // BOS extreme includes every scanned bar, incl. the stop-candle
        hi_seen := math.max(hi_seen, high[i])
        if is_green                                 // green → in leg
            best_open := na(best_open) ? open[i] : math.min(best_open, open[i])
            continue
        if red_pause
            continue                                // mid-leg pause: skip
        break                                       // red-that-held or doji → stop
    [best_open, leg_lo]

// ════════════════ Line state (single mode: sticky + bright-freeze) ════════════════
// v0.4.0: the old default (re-anchor on every sweep) is GONE — sticky is the
// only behavior, with brightness on top:
//   • The line locks at its current OB. It relocates when (a) its anchor
//     low/high is wicked out (fires INTRABAR — repaints on the forming bar but
//     commits identically at close), or (b) after a structure break (confirmed
//     close beyond the leg-origin `*_bos`) the next same-side sweep re-walks.
//     The first OB per side is bootstrapped by a plain sweep.
//   • BRIGHT-FREEZE: while the line is BRIGHT — reclaimed (confirmed close
//     beyond it on a bar after the setting bar) and untested since — ALL
//     relocation is suppressed. The ONLY unlock is a TOUCH of the level (the
//     retest that also starts the dulling). No BOS escape: a never-retested
//     bright line holds indefinitely.
//   • v0.4.1: once a line has EVER brightened (`*_closed_above/below`, which
//     persists until relocation), the post-BOS SWEEP path is permanently dead
//     for it — after the touch it holds its level, and only an anchor
//     wick-out (a true violation of the OB extreme) can relocate it. The
//     BOS+sweep reset applies only to lines that never got reclaimed.
bool active     = time >= start_ts                   // state machine is dead before the start date
bool bull_sweep = close < open and low  < low[1]    // red, new low
bool bear_sweep = close > open and high > high[1]    // green, new high

var float lower_line       = na
var float upper_line       = na
var float bull_anchor_low  = na    // low of the sweep candle currently holding lower_line
var float bull_bos         = na    // bullish leg-origin / structure level
var bool  bull_broken      = false // has price closed above bull_bos since anchoring?
var float bear_anchor_high = na
var float bear_bos         = na
var bool  bear_broken      = false
var bool  bull_touched      = false   // level retested from above (latched until reloc)
var bool  bull_closed_above = false   // level reclaimed (armed)
var bool  bear_touched      = false
var bool  bear_closed_below = false

// Bullish (lower / demand)
if barstate.isconfirmed and not na(bull_bos) and close > bull_bos
    bull_broken := true
bool bull_prev_touched = bull_touched   // state before this bar's touch
bool bull_locked = bull_closed_above and not bull_prev_touched   // bright = frozen (touch is the only unlock)
bool bull_wick = active and not na(bull_anchor_low) and low < bull_anchor_low          // intrabar
bool bull_conf = active and barstate.isconfirmed and (na(bull_anchor_low) ? bull_sweep : (bull_broken and bull_sweep and not bull_closed_above))
bool bull_reloc = (bull_wick or bull_conf) and not bull_locked
if bull_reloc
    int s0b = close < open ? 0 : 1
    [oRb, swb] = f_walkback_bull(max_lookback, s0b, start_ts)
    lower_line      := oRb
    bull_anchor_low := low
    bull_bos        := swb
    bull_broken     := false

// Bearish (upper / supply)
if barstate.isconfirmed and not na(bear_bos) and close < bear_bos
    bear_broken := true
bool bear_prev_touched = bear_touched   // state before this bar's touch
bool bear_locked = bear_closed_below and not bear_prev_touched   // bright = frozen
bool bear_wick = active and not na(bear_anchor_high) and high > bear_anchor_high       // intrabar
bool bear_conf = active and barstate.isconfirmed and (na(bear_anchor_high) ? bear_sweep : (bear_broken and bear_sweep and not bear_closed_below))
bool bear_reloc = (bear_wick or bear_conf) and not bear_locked
if bear_reloc
    int s0s = close > open ? 0 : 1
    [oRs, sws] = f_walkback_bear(max_lookback, s0s, start_ts)
    upper_line       := oRs
    bear_anchor_high := high
    bear_bos         := sws
    bear_broken      := false

// ════════════════ Line freshness (render state) ════════════════
// BRIGHT = reclaimed and not retested since. Green: arms when a bar AFTER the
// setting bar CONFIRMS a close above the line (the arming bar's pass-through
// wick doesn't count, nor do pre-reclaim wicks from below). Once armed, the
// first low back at the line latches "touched" → dull until relocation (no
// re-arm). The FIRST touch bar itself stays bright (colour reads the prior
// bar's touched state). Red: exact mirror.
if bull_reloc
    bull_touched      := false
    bull_closed_above := false
else if not na(lower_line)
    if bull_closed_above and low <= lower_line
        bull_touched := true
    else if not bull_touched and barstate.isconfirmed and close > lower_line
        bull_closed_above := true

if bear_reloc
    bear_touched      := false
    bear_closed_below := false
else if not na(upper_line)
    if bear_closed_below and high >= upper_line
        bear_touched := true
    else if not bear_touched and barstate.isconfirmed and close < upper_line
        bear_closed_below := true

bool  bull_bright = bull_closed_above and not bull_prev_touched
bool  bear_bright = bear_closed_below and not bear_prev_touched
color lower_col   = bull_bright ? color.new(color.green, 0) : color.new(color.green, 60)
color upper_col   = bear_bright ? color.new(color.red, 0)   : color.new(color.red, 60)

// ════════════════ Render ════════════════
plot(lower_line, "OB lower (demand open_R)", lower_col, 2, plot.style_stepline)
plot(upper_line, "OB upper (supply open_R)", upper_col, 2, plot.style_stepline)
plot(bull_bright ? 1 : 0, "DW lower fresh (1=bright)", display = display.data_window)
plot(bear_bright ? 1 : 0, "DW upper fresh (1=bright)", display = display.data_window)

// ════════════════ Version tag ════════════════
var table vt = table.new(position.top_right, 1, 1)
if barstate.islast
    table.cell(vt, 0, 0, "Jamal OB v" + SCRIPT_V, text_color = color.white, bgcolor = color.new(color.black, 20))

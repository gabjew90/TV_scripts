//@version=6
// JAMAL CONTEXT — discretionary regime + pullback + flow context tool.
// DISCRETIONARY CONTEXT, UNVALIDATED, NOT A BACKTESTED EDGE. Displays market STATE; the trader decides.
// Brightness (later increments) = untuned co-occurrence COUNT, never a score; more aligned != higher odds.
// v0.1.4 = Mechanism A (regime) only: SLOPE-LED backbone + CHANDELIER one-way invalidation, TF-NORMALIZED.
//   * Backbone (entry): persistent signed linreg slope, signed Schmitt + dwell. ER demoted to cascade/
//     display filter only. Slope decides WHEN to ENTER a trend (slow, chop-resistant, clean Range).
//   * Chandelier (exit only): chand_dir STRUCTURAL direction — bullish only on a FRESH HIGH; bearish on
//     a long-stop break OR fresh low (highest/lowest CLOSE, ATR x3). Forces regime->Range immediately on
//     disagreement (bypasses dwell). Re-green needs a NEW HIGH (a lower-high bounce in a dump stays gray).
//     Chandelier may ONLY invalidate (+-1 -> 0), NEVER promote: regime = slope_dir AND chand_dir agree.
//   * TF-NORMALIZE: all windows are bar-counts referenced to 4h; effective bars scale by 4h/current_TF so
//     the regime means the SAME wall-clock horizon on any timeframe (1h->x4, 4h->x1, 1D->/6). Without
//     this, 1h measured a ~2-day "trend" and flipped green on every bounce. 4h is unchanged (factor 1.0).
// overlay=false (own pane); the chandelier stop is the only price-pane element (force_overlay), for review.
// VERSION: bump title + shorttitle + panel row together each increment.
indicator("Jamal Context v0.1.4 (regime - tf-normalized)", "JC v0.1.4", overlay=false)

// ===== Inputs (window lengths are 4h-REFERENCE bar counts; see tf_normalize) =====
norm_tf          = input.bool(true, "Normalize windows to wall-clock (4h reference)", group="Regime")
slope_len        = input.int(50,    "Regime slope length (4h-ref bars)", minval=10, group="Regime")
slope_enter      = input.float(0.05, "Slope trend ENTER (ATR/bar)", minval=0.0, step=0.01, group="Regime")
slope_exit       = input.float(0.02, "Slope trend EXIT (ATR/bar)",  minval=0.0, step=0.01, group="Regime")
regime_min_dwell = input.int(3,     "Regime min dwell (4h-ref bars)", minval=1, group="Regime")
k_decontam       = input.int(3,     "Decontaminate recent (4h-ref bars)", minval=0, group="Regime")
atr_len          = input.int(20,    "ATR length (4h-ref bars)", minval=2, group="Regime")
use_ce           = input.bool(true, "Chandelier trend-invalidation (fast exit)", group="Chandelier")
ce_len           = input.int(22,    "Chandelier lookback (4h-ref bars, close)", minval=5, group="Chandelier")
ce_mult          = input.float(3.0, "Chandelier ATR mult", minval=1.0, step=0.5, group="Chandelier")
er_len           = input.int(20,    "Efficiency Ratio length (4h-ref bars; cascade/display)", minval=5, group="Regime")
vol_pct_len      = input.int(250,   "Vol percentile lookback (4h-ref bars; cascade)", minval=50, group="Regime")
vol_hi           = input.float(80,  "Vol-hot percentile (cascade)", minval=50, maxval=99, step=1, group="Regime")
er_cascade       = input.float(0.45, "ER cascade threshold (Flush filter)", minval=0.3, maxval=0.99, step=0.01, group="Regime")
vsma_len         = input.int(20,    "Volume MA length (4h-ref bars; surge)", minval=5, group="Regime")
vsurge_mult      = input.float(1.8, "Volume surge multiple", minval=1.0, step=0.1, group="Regime")
show_tint        = input.bool(true, "Tint pane by regime", group="Display")
show_panel       = input.bool(true, "Show state panel", group="Display")
show_ce          = input.bool(true, "Plot active chandelier stop (price pane)", group="Display")

// ===== TF normalization: scale 4h-reference bar counts to the current timeframe =====
tf_factor = norm_tf ? 14400.0 / timeframe.in_seconds() : 1.0   // 4h ref: 1h->4, 4h->1, 1D->~0.167
f_norm(n, lo) => math.max(lo, math.round(n * tf_factor))
slope_len_e = f_norm(slope_len, 10)
atr_len_e   = f_norm(atr_len, 2)
ce_len_e    = f_norm(ce_len, 5)
er_len_e    = f_norm(er_len, 5)
vol_pct_e   = f_norm(vol_pct_len, 30)
vsma_e      = f_norm(vsma_len, 5)
dwell_e     = f_norm(regime_min_dwell, 1)
k_dec_e     = f_norm(k_decontam, 0)

// ===== Mechanism A: Structure / Regime =====
atr      = ta.atr(atr_len_e)
safe_atr = atr > 0 ? atr : na
atr_os   = safe_atr[k_dec_e]

// --- Backbone: persistent signed slope of the regime linreg, in ATR/bar ---
reg_lr_end  = ta.linreg(close[k_dec_e], slope_len_e, 0)
reg_lr_prev = ta.linreg(close[k_dec_e], slope_len_e, 1)
slope_pb    = reg_lr_end - reg_lr_prev
slope_atr   = (na(atr_os) or atr_os == 0) ? na : slope_pb / atr_os

var int slope_dir = 0
if not na(slope_atr)
    hold_up = slope_dir == 1  and slope_atr >=  slope_exit
    hold_dn = slope_dir == -1 and slope_atr <= -slope_exit
    slope_dir := hold_up ? 1 : hold_dn ? -1 : (slope_atr > slope_enter ? 1 : slope_atr < -slope_enter ? -1 : 0)

// --- Chandelier stops (ratcheting; highest/lowest CLOSE) ---
hhc = ta.highest(close, ce_len_e)
llc = ta.lowest(close, ce_len_e)
var float longStop = na
ls_raw = hhc - ce_mult * atr
longStop := (not na(longStop[1]) and close[1] > longStop[1]) ? math.max(ls_raw, longStop[1]) : ls_raw
var float shortStop = na
ss_raw = llc + ce_mult * atr
shortStop := (not na(shortStop[1]) and close[1] < shortStop[1]) ? math.min(ss_raw, shortStop[1]) : ss_raw

// --- ER demoted: cascade filter + display only ---
er_den = math.sum(math.abs(close - close[1]), er_len_e)
er     = er_den > 0 ? math.abs(close - close[er_len_e]) / er_den : na
atr_pct   = ta.percentrank(atr, vol_pct_e)
vol_ma    = ta.sma(volume, vsma_e)
vol_surge = not na(vol_ma) and vol_ma > 0 and volume > vol_ma * vsurge_mult
cascade   = not na(er) and er >= er_cascade and not na(atr_pct) and atr_pct >= vol_hi and vol_surge

// --- Chandelier dir: STRUCTURAL direction (the invalidation gate) ---
hi_ref = ta.highest(close, ce_len_e)
lo_ref = ta.lowest(close, ce_len_e)
new_hi = not na(hi_ref[1]) and close > hi_ref[1]
new_lo = not na(lo_ref[1]) and close < lo_ref[1]
brk_long = not na(longStop[1]) and close < longStop[1]
var int chand_dir = 1
chand_dir := (brk_long or new_lo) ? -1 : new_hi ? 1 : nz(chand_dir[1], 1)

// --- Regime state machine: slope+dwell decides ENTRY; chandelier can only INVALIDATE (force Range) ---
var int regime = 0
var int regime_dwell = 0
int desired = cascade ? (slope_atr < 0 ? -2 : 2) : slope_dir
regime_dwell += 1
if cascade
    regime := desired
    regime_dwell := 0
else if desired != regime and regime_dwell >= dwell_e
    regime := desired
    regime_dwell := 0

if use_ce and regime == 1 and chand_dir == -1
    regime := 0
if use_ce and regime == -1 and chand_dir == 1
    regime := 0

// --- reg-mix counters (acceptance test #4: Range should stay dominant) ---
var int nTrend = 0
var int nRange = 0
var int nFlush = 0
if barstate.isconfirmed
    if math.abs(regime) == 2
        nFlush += 1
    else if regime != 0
        nTrend += 1
    else
        nRange += 1
int nTot = nTrend + nRange + nFlush
float pRange = nTot > 0 ? 100.0 * nRange / nTot : na
float pTrend = nTot > 0 ? 100.0 * nTrend / nTot : na
float pFlush = nTot > 0 ? 100.0 * nFlush / nTot : na

// ===== Render: own-pane regime ribbon + chandelier stop on price =====
color reg_col = regime == 1 ? #00C853 : regime == -1 ? #FF1744 : math.abs(regime) == 2 ? #FF6D00 : color.gray
color reg_bg = na
if show_tint
    reg_bg := regime == 1 ? color.new(#00C853, 86) : regime == -1 ? color.new(#FF1744, 86) : (math.abs(regime) == 2 ? color.new(#FF6D00, 78) : color.new(color.gray, 92))
bgcolor(reg_bg, title="Regime tint")
plot(regime, "Regime state", color=reg_col, style=plot.style_stepline, linewidth=2)
hline(0,  "0",  color=color.new(color.gray, 70))
hline(2,  "Flush+",  color=color.new(color.gray, 85))
hline(-2, "Flush-",  color=color.new(color.gray, 85))

ce_active = regime == 1 ? longStop : regime == -1 ? shortStop : na
plot(show_ce and use_ce ? ce_active : na, "Chandelier stop", color=color.new(#FFD54F, 10), style=plot.style_stepline, linewidth=1, force_overlay=true)

string reg_label = regime == 1 ? "Trend-up" : regime == -1 ? "Trend-down" : math.abs(regime) == 2 ? "Flush" : "Range"
color  reg_bgc   = regime == 1 ? color.new(#00C853, 0) : regime == -1 ? color.new(#FF1744, 0) : math.abs(regime) == 2 ? color.new(#FF6D00, 0) : color.new(color.gray, 40)

var table panel = table.new(position.top_right, 2, 8, border_color=color.new(color.gray,50), border_width=1, frame_color=color.new(color.gray,50), frame_width=1)
if show_panel and barstate.islast
    string forming = barstate.isconfirmed ? " (confirmed)" : " (forming)"
    table.cell(panel, 0, 0, "Jamal Context", text_color=color.white, bgcolor=color.new(#5E35B1, 0), text_size=size.tiny)
    table.cell(panel, 1, 0, "v0.1.4", text_color=color.white, bgcolor=color.new(#5E35B1, 0), text_size=size.tiny)
    table.cell(panel, 0, 1, "Regime", text_color=color.silver, text_size=size.tiny)
    table.cell(panel, 1, 1, reg_label + forming, text_color=color.white, bgcolor=reg_bgc, text_size=size.tiny)
    table.cell(panel, 0, 2, "Slope ATR/bar", text_color=color.silver, text_size=size.tiny)
    table.cell(panel, 1, 2, str.tostring(slope_atr, "#.000"), text_color=color.white, text_size=size.tiny)
    table.cell(panel, 0, 3, "Win slope/ce (bars)", text_color=color.silver, text_size=size.tiny)
    table.cell(panel, 1, 3, str.tostring(slope_len_e) + "/" + str.tostring(ce_len_e), text_color=color.white, text_size=size.tiny)
    table.cell(panel, 0, 4, "Chand stop", text_color=color.silver, text_size=size.tiny)
    table.cell(panel, 1, 4, na(ce_active) ? "—" : str.tostring(ce_active, "#"), text_color=color.white, text_size=size.tiny)
    table.cell(panel, 0, 5, "Mix R/T/F %", text_color=color.silver, text_size=size.tiny)
    table.cell(panel, 1, 5, str.tostring(pRange, "#") + "/" + str.tostring(pTrend, "#") + "/" + str.tostring(pFlush, "#"), text_color=color.white, text_size=size.tiny)
    table.cell(panel, 0, 6, "ER (filter)", text_color=color.silver, text_size=size.tiny)
    table.cell(panel, 1, 6, str.tostring(er, "#.00"), text_color=color.white, text_size=size.tiny)
    table.cell(panel, 0, 7, "Vol pctile", text_color=color.silver, text_size=size.tiny)
    table.cell(panel, 1, 7, str.tostring(atr_pct, "#.0") + " %", text_color=color.white, text_size=size.tiny)

// data-window readouts
plot(slope_atr, "slope_atr", display=display.data_window)
plot(longStop,  "longStop",  display=display.data_window)
plot(shortStop, "shortStop", display=display.data_window)
plot(er,        "ER",        display=display.data_window)

//@version=6
// Phase 2 data-availability spike. Uses the official TradingView/Request library (NOT raw
// request.security suffixes). Result (BTC 1h, 2026-06-06): OI, Funding Rate, Liquidations Buy &
// Sell ALL available gapless over the full ~2.4y window via the library. See CHANGELOG Phase 2.
indicator("P2 data spike v2 (TV Request lib)", overlay=false)
import TradingView/Request/3 as r

oi_tf_eff = timeframe.period

[_oo, _oh, _ol, oi_close, _orising] = r.openInterestCrypto(symbol = syminfo.tickerid, timeframe = oi_tf_eff)
funding   = r.cryptoDerivativeMetric(metricName = "Funding Rate",      symbol = syminfo.tickerid, timeframe = oi_tf_eff)
liq_buy   = r.cryptoDerivativeMetric(metricName = "Liquidations Buy",  symbol = syminfo.tickerid, timeframe = oi_tf_eff)
liq_sell  = r.cryptoDerivativeMetric(metricName = "Liquidations Sell", symbol = syminfo.tickerid, timeframe = oi_tf_eff)

f_cnt(v) =>
    var int c = 0
    if not na(v)
        c += 1
    c
f_span(v) =>
    var int fb = na
    if not na(v) and na(fb)
        fb := bar_index
    na(fb) ? 0 : bar_index - fb + 1
f_last(v) =>
    var float l = na
    if not na(v)
        l := v
    l

n_oi=f_cnt(oi_close), s_oi=f_span(oi_close), l_oi=f_last(oi_close)
n_fg=f_cnt(funding),  s_fg=f_span(funding),  l_fg=f_last(funding)
n_lb=f_cnt(liq_buy),  s_lb=f_span(liq_buy),  l_lb=f_last(liq_buy)
n_ls=f_cnt(liq_sell), s_ls=f_span(liq_sell), l_ls=f_last(liq_sell)
tot = bar_index + 1

var table t = table.new(position.top_left, 4, 6, border_color=color.gray, border_width=1, frame_color=color.gray, frame_width=1)
if barstate.islast
    table.cell(t,0,0,"series",text_color=color.silver,text_size=size.normal)
    table.cell(t,1,0,"nonNA",text_color=color.silver,text_size=size.normal)
    table.cell(t,2,0,"span",text_color=color.silver,text_size=size.normal)
    table.cell(t,3,0,"last",text_color=color.silver,text_size=size.normal)
    table.cell(t,0,1,"OI close",text_color=color.silver,text_size=size.normal)
    table.cell(t,1,1,str.tostring(n_oi),text_color=n_oi>0?color.lime:color.red,text_size=size.normal)
    table.cell(t,2,1,str.tostring(s_oi),text_color=color.white,text_size=size.normal)
    table.cell(t,3,1,na(l_oi)?"NA":str.tostring(l_oi,"#.##"),text_color=color.white,text_size=size.normal)
    table.cell(t,0,2,"Funding",text_color=color.silver,text_size=size.normal)
    table.cell(t,1,2,str.tostring(n_fg),text_color=n_fg>0?color.lime:color.red,text_size=size.normal)
    table.cell(t,2,2,str.tostring(s_fg),text_color=color.white,text_size=size.normal)
    table.cell(t,3,2,na(l_fg)?"NA":str.tostring(l_fg,"#.######"),text_color=color.white,text_size=size.normal)
    table.cell(t,0,3,"Liq Buy",text_color=color.silver,text_size=size.normal)
    table.cell(t,1,3,str.tostring(n_lb),text_color=n_lb>0?color.lime:color.red,text_size=size.normal)
    table.cell(t,2,3,str.tostring(s_lb),text_color=color.white,text_size=size.normal)
    table.cell(t,3,3,na(l_lb)?"NA":str.tostring(l_lb,"#.##"),text_color=color.white,text_size=size.normal)
    table.cell(t,0,4,"Liq Sell",text_color=color.silver,text_size=size.normal)
    table.cell(t,1,4,str.tostring(n_ls),text_color=n_ls>0?color.lime:color.red,text_size=size.normal)
    table.cell(t,2,4,str.tostring(s_ls),text_color=color.white,text_size=size.normal)
    table.cell(t,3,4,na(l_ls)?"NA":str.tostring(l_ls,"#.##"),text_color=color.white,text_size=size.normal)
    table.cell(t,0,5,"total bars",text_color=color.silver,text_size=size.normal)
    table.cell(t,1,5,str.tostring(tot),text_color=color.white,text_size=size.normal)

plot(na)

//@version=6
indicator("Jamal Fable v0.6.2", shorttitle = "JFbl0.6.2", overlay = true,
     max_labels_count = 500, max_lines_count = 500)
import TradingView/Request/3 as r
import TradingView/ta/9 as tvta

// ════════════════ Identity (spec §9 provenance) ════════════════
SCHEMA_V = "1"
SCRIPT_V = "0.6.2"

// ════════════════ Knobs (§12) — semantic; ALL feed settings_hash ════════════════
pivot_left            = input.int(3,    "Pivot left bars",          minval = 1)
pivot_right           = input.int(3,    "Pivot right bars",         minval = 1)
atr_period            = input.int(14,   "ATR period",               minval = 1)
stop_buffer_atr       = input.float(0.5, "Stop buffer (ATR mult)",  step = 0.1)
rr_min                = input.float(1.5, "Min R to T1 (skip gate)", step = 0.1)
quadrant_window       = input.int(14,   "Quadrant window")
funding_pctile_window = input.int(200,  "Funding pctile window")
wick_pctile_window    = input.int(200,  "Wick pctile window")
os_linreg_window      = input.int(50,   "Overshoot linreg window",  minval = 5)
os_pctile_window      = input.int(200,  "Overshoot pctile window")
er_window             = input.int(20,   "Efficiency ratio window",  minval = 2)
vz_window             = input.int(100,  "Volume z-score window",    minval = 10)
piv_n                 = input.int(5,    "OS: last-N pivots per side", minval = 1)
roll_k                = input.int(20,   "OS: rolling extreme window", minval = 5)
os_m                  = input.int(5,    "OS: stretch lookback (bars)", minval = 1)
os_gate_atr           = input.float(1.5, "OS: roll-class stretch gate (ATR)", step = 0.1)
use_1d_gate           = input.bool(false, "Use 1D regime gate (campaign-era behavior)")
os_use_piv            = input.bool(false, "OS: sweep last-N pivots (campaign-2: 23%/-0.07R)")
os_use_roll           = input.bool(false, "OS: sweep rolling extreme (campaign-2: 22%/-0.10R)")

// Transport-layer inputs — EXCLUDED from settings_hash (they chunk the label
// budget; they change which events are emitted, never what an event means).
emit_from = input.time(timestamp("2026-04-01T00:00:00+00:00"), "Emit events from (UTC)")
emit_to   = input.time(timestamp("2027-01-01T00:00:00+00:00"), "Emit events to (UTC)")

// Display-layer input — EXCLUDED from settings_hash (rendering only). OFF by
// default: the event labels are the machine transport, not chart annotations.
// They are still CREATED when hidden (fully transparent) so the MCP harvest
// can read them — suppressing creation would leave nothing to harvest.
show_labels = input.bool(false, "Show transport labels (DEBUG only — unreadable by design)")

// ════════════════ settings_hash (deterministic over semantic knobs) ════════════════
f_mix(int acc, int v) => (acc * 31 + v) % 1000003

var int cfg_i = 0
if barstate.isfirst
    int h = 17
    h := f_mix(h, pivot_left)
    h := f_mix(h, pivot_right)
    h := f_mix(h, atr_period)
    h := f_mix(h, math.round(stop_buffer_atr * 1000))
    h := f_mix(h, math.round(rr_min * 1000))
    h := f_mix(h, quadrant_window)
    h := f_mix(h, funding_pctile_window)
    h := f_mix(h, wick_pctile_window)
    h := f_mix(h, os_linreg_window)
    h := f_mix(h, os_pctile_window)
    h := f_mix(h, er_window)
    h := f_mix(h, vz_window)
    h := f_mix(h, piv_n)
    h := f_mix(h, roll_k)
    h := f_mix(h, os_m)
    h := f_mix(h, math.round(os_gate_atr * 1000))
    h := f_mix(h, use_1d_gate ? 1 : 0)
    h := f_mix(h, os_use_piv ? 1 : 0)
    h := f_mix(h, os_use_roll ? 1 : 0)
    cfg_i := h

// ════════════════ ATR (SMA of TR — cross-language reproducible) ════════════════
atr = ta.sma(ta.tr(true), atr_period)

// ════════════════ Event emission (§9 label transport) ════════════════
// Half-open window [emit_from, emit_to): adjacent chunks can't double-emit the boundary bar.
in_window = time >= emit_from and time < emit_to

f_emit(string trade, string event, string dir, int ts_sec, float px, string tail) =>
    if in_window and barstate.isconfirmed
        string txt = "JF|" + SCHEMA_V + "|" + SCRIPT_V + "|" + str.tostring(cfg_i)
             + "|B|" + trade + "|" + event + "|" + dir + "|" + timeframe.period
             + "|" + str.tostring(ts_sec) + "|" + str.tostring(px, "#.########")
             + (tail == "" ? "" : "|" + tail)
        // text = the machine transport (harvested); tooltip = the same event
        // formatted vertically for HUMAN hover-inspection (readable regardless
        // of overlap — zoom in and hover a box).
        label.new(bar_index, high, txt, style = label.style_label_down,
             color = color.new(color.gray, show_labels ? 85 : 100),
             textcolor = color.new(color.black, show_labels ? 30 : 100),
             size = size.tiny, tooltip = str.replace_all(txt, "|", "\n"))

f_reg_str(int rg) => rg == 1 ? "U" : rg == -1 ? "D" : "C"

f_fstr(float x) => na(x) ? "na" : str.tostring(x, "#.########")

// ════════════════ Human entry marks (the readable layer) ════════════════
// Every ENTRY gets a small colored tag (T1/2A/2B) whose hover-tooltip is the
// full event card. Entries are rare → no overlap. Everything else (ARM/SKP/
// CXL/SYS) lives only in the invisible transport layer + the harvest.
f_mark(string trade, string dir, float px, string tail) =>
    if in_window and barstate.isconfirmed   // v0.4.5: chips share the emit window —
                                            // all-history chips were eating the label
                                            // budget (265 on BTC) at the eviction cliff
        string card = trade + (dir == "L" ? " LONG @ " : " SHORT @ ")
             + str.tostring(px, "#.########") + "\n" + str.replace_all(tail, "|", "\n")
        if dir == "L"
            label.new(bar_index, low, trade, style = label.style_label_up,
                 color = color.new(color.lime, 0), textcolor = color.black,
                 size = size.small, tooltip = card)
        else
            label.new(bar_index, high, trade, style = label.style_label_down,
                 color = color.new(color.red, 0), textcolor = color.white,
                 size = size.small, tooltip = card)

// ════════════════ Engine as a pure function (no emission side-effects) ════════════════
// var locals = one independent state copy PER CALLING CONTEXT (chart, 1D security).
// Pivot bookkeeping BEFORE FSM on the same confirmed bar (engine detail #6);
// ALL state mutation confirmed-bar gated (engine detail #7).
f_engine() =>
    var int   regime     = 0      // 0=CHOP, 1=UP, -1=DOWN
    var int   regime_age = 0
    var float hl_ref     = na     // UP: most recent confirmed pivot low while live
    var float lh_ref     = na     // DOWN: most recent confirmed pivot high while live
    var float trend_high = na     // UP: most recent confirmed pivot high
    var float trend_low  = na     // DOWN: most recent confirmed pivot low
    var float range_hi   = na     // CHOP boundaries (na = undefined side, §3 seeding)
    var float range_lo   = na
    var float bos_level  = na     // last broken level (touched_bz reference)
    var float last_ph    = na
    var float last_pl    = na
    float ph = ta.pivothigh(high, pivot_left, pivot_right)
    float pl = ta.pivotlow(low,  pivot_left, pivot_right)
    bool ph_new = not na(ph) and barstate.isconfirmed
    bool pl_new = not na(pl) and barstate.isconfirmed
    if ph_new
        last_ph := ph
        if regime == 1
            trend_high := ph
        else if regime == -1
            lh_ref := ph                  // re-anchor included by definition (§3)
        else
            range_hi := na(range_hi) ? ph : math.max(range_hi, ph)
    if pl_new
        last_pl := pl
        if regime == -1
            trend_low := pl
        else if regime == 1
            hl_ref := pl                  // re-anchor included by definition (§3)
        else
            range_lo := na(range_lo) ? pl : math.min(range_lo, pl)
    int prev_regime = regime
    if barstate.isconfirmed
        if regime == 0
            if not na(range_hi) and close > range_hi          // CHOP→UP = BOS(up)
                regime     := 1
                bos_level  := range_hi
                hl_ref     := last_pl     // seed: most recent confirmed pivot low (detail #1)
                trend_high := range_hi    // seed: broken boundary (avoids instant-BOS artifact)
            else if not na(range_lo) and close < range_lo     // CHOP→DOWN
                regime    := -1
                bos_level := range_lo
                lh_ref    := last_ph
                trend_low := range_lo
        else if regime == 1
            if not na(hl_ref) and close < hl_ref              // CHoCH: UP→CHOP (never UP→DOWN)
                regime   := 0
                range_hi := trend_high    // seed opposite boundary w/ dead trend's extreme
                range_lo := na            // broken side undefined until first post-death pivot
            else if not na(trend_high) and close > trend_high
                bos_level := trend_high   // continuation BOS — no state change
        else  // regime == -1
            if not na(lh_ref) and close > lh_ref              // CHoCH: DOWN→CHOP
                regime   := 0
                range_lo := trend_low
                range_hi := na
            else if not na(trend_low) and close < trend_low
                bos_level := trend_low
        if regime != prev_regime
            regime_age := 0
        else
            regime_age += 1
    bool reg_changed = barstate.isconfirmed and regime != prev_regime
    [regime, regime_age, hl_ref, lh_ref, trend_high, trend_low, range_hi, range_lo, bos_level, ph_new, ph, pl_new, pl, reg_changed]

// ════════════════ Chart-context engine instance ════════════════
[regime, regime_age, hl_ref, lh_ref, trend_high, trend_low, range_hi, range_lo, bos_level, ph_new, ph_val, pl_new, pl_val, reg_changed] = f_engine()

// ════════════════ 1D regime filter (last CONFIRMED 1D bar; non-repainting) ════════════════
// [1] + lookahead_on = the classic non-repaint HTF pattern: always the last
// CLOSED D bar's regime. The security call gets its OWN f_engine state copy.
f_engine_reg() =>
    [rg, _a, _hl, _lh, _th, _tl, _rh, _rl, _bl, _pn, _pv, _qn, _qv, _rc] = f_engine()
    rg

int reg_1d = request.security(syminfo.tickerid, "D", f_engine_reg()[1],
     lookahead = barmerge.lookahead_on)

// ════════════════ Derivatives via official TradingView/Request library (v0.4.6) ════════════════
// Perpetuals only — spot symbols return na everywhere; let na propagate.
// NEVER nz() raw OI: nz(oi[1]) fabricates a 0 prior → spurious giant bar-1 delta.
// (Replaces the raw <ticker>_OI security feed AND deletes the OI-override
// input.symbol — whose garbage-value study-kill hazard goes with it.)
[_oo, _oh, _ol, oi_close, _orising] = r.openInterestCrypto(symbol = syminfo.tickerid, timeframe = timeframe.period)
float oi = oi_close
float fr  = r.cryptoDerivativeMetric(metricName = "Funding Rate",      symbol = syminfo.tickerid, timeframe = timeframe.period)
float lqb = r.cryptoDerivativeMetric(metricName = "Liquidations Buy",  symbol = syminfo.tickerid, timeframe = timeframe.period)  // SHORTS force-closed
float lqs = r.cryptoDerivativeMetric(metricName = "Liquidations Sell", symbol = syminfo.tickerid, timeframe = timeframe.period)  // LONGS force-closed

// Funding proxy: Binance _PREMIUM derivative-metrics feed when available (the
// premium index that drives funding); else perp-vs-spot premium. Units don't
// matter — fp is a percentrank, which is rank-invariant.
float prem_feed = request.security(syminfo.prefix + ":" + syminfo.ticker + "_PREMIUM",
     timeframe.period, close, ignore_invalid_symbol = true)
string spot_tkr = syminfo.prefix + ":" + str.replace(syminfo.ticker, ".P", "")
float spot_px = request.security(spot_tkr, timeframe.period, close, ignore_invalid_symbol = true)
float prem = not na(prem_feed) ? prem_feed : na(spot_px) or spot_px == 0 ? na : 100.0 * (close - spot_px) / spot_px
float prem_rank = ta.percentrank(prem, funding_pctile_window)   // called every bar (consistency)
float fp = na(prem) ? na : prem_rank

// Quadrant: sign(dPrice) x sign(dOI) over quadrant_window (crude by design).
float q_dpx = close - close[quadrant_window]
float q_doi = na(oi) or na(oi[quadrant_window]) ? na : oi - oi[quadrant_window]
string quad = na(q_doi) ? "na" : (q_dpx >= 0 ? "PU" : "PD") + "." + (q_doi >= 0 ? "OU" : "OD")

// Per-bar OI change (%): the sweep-bar delta for 2A/2B and the trigger direction for T1.
float oi_chg = na(oi) or na(oi[1]) or oi[1] == 0 ? na : 100.0 * (oi - oi[1]) / oi[1]
string oi_t_dir = na(oi_chg) ? "na" : oi_chg >= 0 ? "up" : "dn"

f_oi_d_from(float oi0) => na(oi) or na(oi0) or oi0 == 0 ? na : 100.0 * (oi - oi0) / oi0
f_gvb(float lvl) => na(lvl) or na(atr) or atr == 0 ? na : math.abs(close - lvl) / atr

// ════════════════ v0.4.6 covariates (spec §8; logged, never gate) ════════════════
// Overshoot: linreg anchor on [1] so the signal bar never drags the fit.
// os is SIGNED (above/below anchor); osp ranks |os| (stretch magnitude).
float lr_anchor = ta.linreg(close, os_linreg_window, 0)[1]
float os_raw  = na(lr_anchor) or na(atr) or atr == 0 ? na : (close - lr_anchor) / atr
float os_rank = ta.percentrank(math.abs(os_raw), os_pctile_window)   // unconditional (consistency)

// Kaufman efficiency ratio
float er_num = math.abs(close - close[er_window])
float er_den = math.sum(math.abs(close - close[1]), er_window)
float er = na(er_den) or er_den == 0 ? na : er_num / er_den

// Volume z-score on the signal bar
float v_std  = ta.stdev(volume, vz_window)
float v_mean = ta.sma(volume, vz_window)
float vz = na(v_std) or v_std == 0 ? na : (volume - v_mean) / v_std

// CVD: this bar's net volume delta from 60-min intrabars (na where unavailable).
[dlt_o, dlt_max, dlt_min, dlt_c] = tvta.requestVolumeDelta("60")
float dlt = na(dlt_c) or na(dlt_o) ? na : dlt_c - dlt_o

// Level ages (bars since each structural level last changed) — na-safe: an
// na != na comparison is na → false inside barssince, yielding na early-history.
int age_hl  = ta.barssince(hl_ref   != hl_ref[1])
int age_lh  = ta.barssince(lh_ref   != lh_ref[1])
int age_rlo = ta.barssince(range_lo != range_lo[1])
int age_rhi = ta.barssince(range_hi != range_hi[1])

// Shared covariate tail suffix — appended to EVERY trade tail (fixed key order:
// os|osp|er|vz|dlt|fr|lqb|lqs). Append-only per §9 schema discipline.
f_cov_tail() =>
    "os=" + (na(os_raw) ? "na" : str.tostring(os_raw, "#.##"))
     + "|osp=" + (na(os_raw) or na(os_rank) ? "na" : str.tostring(os_rank, "#.#"))
     + "|er=" + (na(er) ? "na" : str.tostring(er, "#.##"))
     + "|vz=" + (na(vz) ? "na" : str.tostring(vz, "#.##"))
     + "|dlt=" + f_fstr(dlt)
     + "|fr=" + (na(fr) ? "na" : str.tostring(fr, "#.######"))
     + "|lqb=" + f_fstr(lqb) + "|lqs=" + f_fstr(lqs)

// ════════════════ v0.5 OS level set (spec §14) ════════════════
var array<float> piv_lows  = array.new<float>()
var array<float> piv_highs = array.new<float>()
if pl_new
    array.push(piv_lows, pl_val)
    if array.size(piv_lows) > piv_n
        array.shift(piv_lows)
if ph_new
    array.push(piv_highs, ph_val)
    if array.size(piv_highs) > piv_n
        array.shift(piv_highs)
// Prior day/week extremes: [1] + lookahead_on = last CLOSED candle (zero lag, non-repainting)
float pdl = request.security(syminfo.tickerid, "D", low[1],  lookahead = barmerge.lookahead_on)
float pdh = request.security(syminfo.tickerid, "D", high[1], lookahead = barmerge.lookahead_on)
float pwl = request.security(syminfo.tickerid, "W", low[1],  lookahead = barmerge.lookahead_on)
float pwh = request.security(syminfo.tickerid, "W", high[1], lookahead = barmerge.lookahead_on)
float roll_lo = ta.lowest(low, roll_k)[1]      // as of PRIOR bar — excludes current
float roll_hi = ta.highest(high, roll_k)[1]
float os_min_m = ta.lowest(os_raw, os_m)        // stretch extreme within last m bars
float os_max_m = ta.highest(os_raw, os_m)
int age_roll_lo = ta.barssince(roll_lo != roll_lo[1])
int age_roll_hi = ta.barssince(roll_hi != roll_hi[1])
int age_pdl = ta.barssince(pdl != pdl[1])
int age_pdh = ta.barssince(pdh != pdh[1])

// ════════════════ Emission ════════════════
if ph_new
    f_emit("SYS", "PIV", "N", math.round(time[pivot_right] / 1000), ph_val, "typ=H")
if pl_new
    f_emit("SYS", "PIV", "N", math.round(time[pivot_right] / 1000), pl_val, "typ=L")
if reg_changed
    f_emit("SYS", "PING", "N", math.round(time / 1000), close,
         "reg=" + f_reg_str(regime) + "|age=0|reg1d=" + f_reg_str(reg_1d))

// ════════════════ Trade #1: pullback-continuation — LONG (spec §5) ════════════════
// Pine constraint: functions cannot reassign global vars → detector state lives
// in a UDT object (field mutation through a reference is allowed).
type T1S
    bool  armed = false
    float mlh   = na      // micro lower-high (chain tip; S3)
    int   mlhn  = 0       // chain length
    float pblow = na      // running pullback low (S2; survives SKP)
    float th    = na      // trend high this pullback keyed off (dissolve detector)
    float oi0   = na      // OI snapshot at pullback start (oi_d reference)
    bool  blk   = false   // blocked-ARM emitted this pullback cycle (v0.4.4: ONE
                          // ARM|rsn=1d per pullback — unbounded re-emission would
                          // silently FIFO-evict real events at the 500-label cap)

var T1S t1l = T1S.new()

f_t1_reset(T1S s, bool full) =>
    s.armed := false
    s.mlh   := na
    s.mlhn  := 0
    if full
        s.pblow := na
        s.th    := na
        s.oi0   := na
        s.blk   := false

// fixed tail key order (schema stability): lvl|stop|t1|rsn|reg|reg1d|age|d_atr|d_pct|bz|mlh|rt1|oi_d|oi_t|q|fp|gvb|<cov>
f_t1_tail(T1S s, float lvl, float stp, float t1px, string rsn, float rt1) =>
    float d_atr = na(s.pblow) or na(s.th) ? na : (s.th - s.pblow) / atr
    float d_pct = na(s.pblow) or na(s.th) or na(lvl) or s.th == lvl ? na :
         100.0 * (s.th - s.pblow) / (s.th - lvl)
    string bz = na(bos_level) or na(s.pblow) ? "na" : s.pblow <= bos_level ? "1" : "0"
    float od = f_oi_d_from(s.oi0)
    float g  = f_gvb(lvl)
    "lvl=" + f_fstr(lvl) + "|stop=" + f_fstr(stp) + "|t1=" + f_fstr(t1px) + "|rsn=" + rsn
     + "|reg=" + f_reg_str(regime) + "|reg1d=" + f_reg_str(reg_1d)
     + "|age=" + str.tostring(regime_age)
     + "|d_atr=" + (na(d_atr) ? "na" : str.tostring(d_atr, "#.##"))
     + "|d_pct=" + (na(d_pct) ? "na" : str.tostring(d_pct, "#.#"))
     + "|bz=" + bz + "|mlh=" + str.tostring(s.mlhn)
     + "|rt1=" + (na(rt1) ? "na" : str.tostring(rt1, "#.##"))
     + "|oi_d=" + (na(od) ? "na" : str.tostring(od, "#.##")) + "|oi_t=" + oi_t_dir
     + "|q=" + quad + "|fp=" + (na(fp) ? "na" : str.tostring(fp, "#.#"))
     + "|gvb=" + (na(g) ? "na" : str.tostring(g, "#.##"))
     + "|" + f_cov_tail()

// (T1 short-side declarations hoisted here — the Trade #2 coincidence captures
// below must read BOTH t1l and t1s state before either detector resets it.)
type T1SS
    bool  armed  = false
    float mhl    = na     // micro higher-low (chain tip)
    int   mhln   = 0
    float pbhigh = na     // running pullback high (survives SKP)
    float tl     = na     // trend low this pullback keyed off (dissolve detector)
    float oi0    = na     // OI snapshot at pullback start (oi_d reference)
    bool  blk    = false  // blocked-ARM emitted this pullback cycle (see T1S.blk)

var T1SS t1s = T1SS.new()

f_t1s_reset(T1SS s, bool full) =>
    s.armed := false
    s.mhl   := na
    s.mhln  := 0
    if full
        s.pbhigh := na
        s.tl     := na
        s.oi0    := na
        s.blk    := false

f_t1s_tail(T1SS s, float lvl, float stp, float t1px, string rsn, float rt1) =>
    float d_atr = na(s.pbhigh) or na(s.tl) ? na : (s.pbhigh - s.tl) / atr
    float d_pct = na(s.pbhigh) or na(s.tl) or na(lvl) or lvl == s.tl ? na :
         100.0 * (s.pbhigh - s.tl) / (lvl - s.tl)
    string bz = na(bos_level) or na(s.pbhigh) ? "na" : s.pbhigh >= bos_level ? "1" : "0"
    float od = f_oi_d_from(s.oi0)
    float g  = f_gvb(lvl)
    "lvl=" + f_fstr(lvl) + "|stop=" + f_fstr(stp) + "|t1=" + f_fstr(t1px) + "|rsn=" + rsn
     + "|reg=" + f_reg_str(regime) + "|reg1d=" + f_reg_str(reg_1d)
     + "|age=" + str.tostring(regime_age)
     + "|d_atr=" + (na(d_atr) ? "na" : str.tostring(d_atr, "#.##"))
     + "|d_pct=" + (na(d_pct) ? "na" : str.tostring(d_pct, "#.#"))
     + "|bz=" + bz + "|mlh=" + str.tostring(s.mhln)
     + "|rt1=" + (na(rt1) ? "na" : str.tostring(rt1, "#.##"))
     + "|oi_d=" + (na(od) ? "na" : str.tostring(od, "#.##")) + "|oi_t=" + oi_t_dir
     + "|q=" + quad + "|fp=" + (na(fp) ? "na" : str.tostring(fp, "#.#"))
     + "|gvb=" + (na(g) ? "na" : str.tostring(g, "#.##"))
     + "|" + f_cov_tail()

// ════════════════ Trade #2 shared (spec §6) ════════════════
// Sweep conditions (§4, one-bar definition) — evaluated once per bar.
bool swp_l = barstate.isconfirmed and regime == 1 and not na(hl_ref) and low < hl_ref and close >= hl_ref
bool swp_s = barstate.isconfirmed and regime == -1 and not na(lh_ref) and high > lh_ref and close <= lh_ref
// §4 coincidence (v0.4.4): set by T1's OWN handoff branch — consistent with the
// CXL|handoff event BY CONSTRUCTION (the old pre-capture checked the previous
// bar's chain and could disagree with a same-bar chain-growth handoff).
bool t2a_l_coin = false
bool t2a_s_coin = false

// Wick-size percentiles (decision #2): relevant wick in ATRs, ranked vs own history.
float wick_lo_atr = (math.min(open, close) - low) / atr
float wick_hi_atr = (high - math.max(open, close)) / atr
float wkp_lo = ta.percentrank(wick_lo_atr, wick_pctile_window)
float wkp_hi = ta.percentrank(wick_hi_atr, wick_pctile_window)

// fixed tail key order: lvl|stop|t1|rsn|reg|reg1d|age|wkp|t1co|rt1|oi_d|q|fp|gvb|swd|age_t|<cov>
f_t2_tail(float lvl, float stp, float t1px, string rsn, float wkp, bool t1co, float rt1, float swd, int aget) =>
    float g = f_gvb(lvl)
    "lvl=" + f_fstr(lvl) + "|stop=" + f_fstr(stp) + "|t1=" + f_fstr(t1px) + "|rsn=" + rsn
     + "|reg=" + f_reg_str(regime) + "|reg1d=" + f_reg_str(reg_1d)
     + "|age=" + str.tostring(regime_age)
     + "|wkp=" + (na(wkp) ? "na" : str.tostring(wkp, "#.#"))
     + "|t1co=" + (t1co ? "1" : "0")
     + "|rt1=" + (na(rt1) ? "na" : str.tostring(rt1, "#.##"))
     + "|oi_d=" + (na(oi_chg) ? "na" : str.tostring(oi_chg, "#.##"))
     + "|q=" + quad + "|fp=" + (na(fp) ? "na" : str.tostring(fp, "#.#"))
     + "|gvb=" + (na(g) ? "na" : str.tostring(g, "#.##"))
     + "|swd=" + (na(swd) ? "na" : str.tostring(swd, "#.##"))
     + "|age_t=" + (na(aget) ? "na" : str.tostring(aget))
     + "|" + f_cov_tail()

// fixed tail key order: lvl|stop|t1|rsn|lvl_src|n_lvls|align|oco|reg|reg1d|age|swd|age_t|rt1|tgt|<cov>
// tgt = target source (v0.6.2 alignment-aware rule): tex=trend extreme (with-regime),
// fv=fair-value anchor (against-regime), mid=range midpoint (chop).
f_os_tail(float lvl, float stp, float t1px, string rsn, string src, int nlv, string align, bool oco, float swd, int aget, float rt1, string tgt) =>
    "lvl=" + f_fstr(lvl) + "|stop=" + f_fstr(stp) + "|t1=" + f_fstr(t1px) + "|rsn=" + rsn
     + "|lvl_src=" + src + "|n_lvls=" + str.tostring(nlv) + "|align=" + align
     + "|oco=" + (oco ? "1" : "0")
     + "|reg=" + f_reg_str(regime) + "|reg1d=" + f_reg_str(reg_1d)
     + "|age=" + str.tostring(regime_age)
     + "|swd=" + (na(swd) ? "na" : str.tostring(swd, "#.##"))
     + "|age_t=" + (na(aget) ? "na" : str.tostring(aget))
     + "|rt1=" + (na(rt1) ? "na" : str.tostring(rt1, "#.##"))
     + "|tgt=" + tgt
     + "|" + f_cov_tail()

// OS chips (v0.6.1 user scheme): with-regime LONG = green, with-regime SHORT = red,
// AGAINST regime (either side) = yellow warning, chop = gray.
f_mark_os(string dir, float px, string tail, string align) =>
    if in_window and barstate.isconfirmed
        color bg = align == "W" ? (dir == "L" ? color.new(color.lime, 0) : color.new(color.red, 0)) :
             align == "A" ? color.new(color.yellow, 0) : color.new(color.gray, 0)
        color tx = align == "W" and dir == "S" ? color.white : align == "N" ? color.white : color.black
        string card = "OS " + (dir == "L" ? "LONG @ " : "SHORT @ ") + str.tostring(px, "#.########")
             + "\n" + str.replace_all(tail, "|", "\n")
        if dir == "L"
            label.new(bar_index, low, "OS", style = label.style_label_up, color = bg,
                 textcolor = tx, size = size.small, tooltip = card)
        else
            label.new(bar_index, high, "OS", style = label.style_label_down, color = bg,
                 textcolor = tx, size = size.small, tooltip = card)

bool t1l_ent_mark = false
if barstate.isconfirmed and regime == 1 and not na(hl_ref) and not na(trend_high)
    // dissolve: a NEW trend high while armed = pullback over without trigger (decision #3)
    if not na(t1l.th) and trend_high > t1l.th
        if t1l.armed
            f_emit("T1", "CXL", "L", math.round(time / 1000), close,
                 f_t1_tail(t1l, hl_ref, na, t1l.th, "newhigh", na))
        f_t1_reset(t1l, true)
    if na(t1l.th)
        t1l.th  := trend_high
        t1l.oi0 := oi                               // OI snapshot at pullback start
    t1l.pblow := na(t1l.pblow) ? low : math.min(t1l.pblow, low)
    // chain growth (S3): a lower low vs prior bar makes prior bar's high the micro-LH
    if low < low[1]
        t1l.mlh  := high[1]
        t1l.mlhn := t1l.mlhn + 1
        if not t1l.armed
            if not use_1d_gate or reg_1d != -1      // S1: 1D gate (knob; default OFF per 2026-06-11 ruling)
                t1l.armed := true
                f_emit("T1", "ARM", "L", math.round(time / 1000), close,
                     f_t1_tail(t1l, hl_ref, na, t1l.th, "na", na))
            else if not t1l.blk                     // v0.4.4: ONE blocked-ARM per pullback cycle
                t1l.blk := true                     // (unbounded re-emission FIFO-evicts real events)
                f_emit("T1", "ARM", "L", math.round(time / 1000), close,
                     f_t1_tail(t1l, hl_ref, na, t1l.th, "1d", na))
    // NOTE: the in-regime "close < hl_ref" branch is unreachable — the engine's
    // FSM (inside f_engine, before this block) flips regime to CHOP on that same
    // bar. Thesis death is emitted from the regime-exit reset below instead.
    if t1l.armed
        if close > t1l.mlh                          // S3 trigger: body close above micro-LH
            if low < hl_ref and close >= hl_ref     // §4 coincidence: SWEEP bar → 2A owns
                t2a_l_coin := true                  // v0.4.4: t1co mirrors THIS handoff exactly
                f_emit("T1", "CXL", "L", math.round(time / 1000), close,
                     f_t1_tail(t1l, hl_ref, na, t1l.th, "handoff", na))
                f_t1_reset(t1l, false)
            else
                float stp = t1l.pblow - stop_buffer_atr * atr
                float rt1 = close > stp ? (t1l.th - close) / (close - stp) : na
                if na(rt1) or rt1 < rr_min          // S5 skip gate
                    f_emit("T1", "SKP", "L", math.round(time / 1000), close,
                         f_t1_tail(t1l, hl_ref, stp, t1l.th, "rr", rt1))
                else
                    string tl_ent = f_t1_tail(t1l, hl_ref, stp, t1l.th, "na", rt1)
                    f_emit("T1", "ENT", "L", math.round(time / 1000), close, tl_ent)
                    f_mark("T1", "L", close, tl_ent)
                    t1l_ent_mark := true
                f_t1_reset(t1l, false)              // chain resets, pullback continues (decision #2)
if barstate.isconfirmed and regime != 1
    if t1l.armed                                    // S4 thesis death: UP only dies via CHoCH
        f_emit("T1", "CXL", "L", math.round(time / 1000), close,
             f_t1_tail(t1l, hl_ref, na, t1l.th, "choch", na))
    f_t1_reset(t1l, true)

// ════════════════ Trade #1: pullback-continuation — SHORT (strict mirror) ════════════════
// (declarations hoisted above the Trade #2 shared block)
bool t1s_ent_mark = false
if barstate.isconfirmed and regime == -1 and not na(lh_ref) and not na(trend_low)
    // dissolve: a NEW trend low while armed = pullback over without trigger
    if not na(t1s.tl) and trend_low < t1s.tl
        if t1s.armed
            f_emit("T1", "CXL", "S", math.round(time / 1000), close,
                 f_t1s_tail(t1s, lh_ref, na, t1s.tl, "newlow", na))
        f_t1s_reset(t1s, true)
    if na(t1s.tl)
        t1s.tl  := trend_low
        t1s.oi0 := oi                               // OI snapshot at pullback start
    t1s.pbhigh := na(t1s.pbhigh) ? high : math.max(t1s.pbhigh, high)
    // chain growth: a higher high vs prior bar makes prior bar's low the micro-HL
    if high > high[1]
        t1s.mhl  := low[1]
        t1s.mhln := t1s.mhln + 1
        if not t1s.armed
            if not use_1d_gate or reg_1d != 1       // S1 mirror: 1D gate (knob; default OFF)
                t1s.armed := true
                f_emit("T1", "ARM", "S", math.round(time / 1000), close,
                     f_t1s_tail(t1s, lh_ref, na, t1s.tl, "na", na))
            else if not t1s.blk                     // v0.4.4: ONE blocked-ARM per pullback cycle
                t1s.blk := true
                f_emit("T1", "ARM", "S", math.round(time / 1000), close,
                     f_t1s_tail(t1s, lh_ref, na, t1s.tl, "1d", na))
    // NOTE: in-regime "close > lh_ref" is unreachable (engine flips first);
    // thesis death emitted from the regime-exit reset below.
    if t1s.armed
        if close < t1s.mhl                          // S3 mirror trigger
            if high > lh_ref and close <= lh_ref    // §4 coincidence: SWEEP of lh_ref → 2A owns
                t2a_s_coin := true                  // v0.4.4: t1co mirrors THIS handoff exactly
                f_emit("T1", "CXL", "S", math.round(time / 1000), close,
                     f_t1s_tail(t1s, lh_ref, na, t1s.tl, "handoff", na))
                f_t1s_reset(t1s, false)
            else
                float stp = t1s.pbhigh + stop_buffer_atr * atr
                float rt1 = stp > close ? (close - t1s.tl) / (stp - close) : na
                if na(rt1) or rt1 < rr_min          // S5 skip gate
                    f_emit("T1", "SKP", "S", math.round(time / 1000), close,
                         f_t1s_tail(t1s, lh_ref, stp, t1s.tl, "rr", rt1))
                else
                    string ts_ent = f_t1s_tail(t1s, lh_ref, stp, t1s.tl, "na", rt1)
                    f_emit("T1", "ENT", "S", math.round(time / 1000), close, ts_ent)
                    f_mark("T1", "S", close, ts_ent)
                    t1s_ent_mark := true
                f_t1s_reset(t1s, false)
if barstate.isconfirmed and regime != -1
    if t1s.armed                                    // S4 mirror: DOWN only dies via CHoCH
        f_emit("T1", "CXL", "S", math.round(time / 1000), close,
             f_t1s_tail(t1s, lh_ref, na, t1s.tl, "choch", na))
    f_t1s_reset(t1s, true)

// ════════════════ Trade #2A: flush-and-reclaim at the kill line (spec §6A) ════════════════
// Stateless one-bar setup: the sweep bar IS the entry bar (entry = its close).
// The only doctrine: no entry without the reclaim close — swp_* encodes it.
bool t2a_ent_long = false
bool t2a_ent_short = false
if swp_l and not na(trend_high)
    float stp = low - stop_buffer_atr * atr
    float rt1 = close > stp ? (trend_high - close) / (close - stp) : na
    if use_1d_gate and reg_1d == -1                 // 1D gate knob (default OFF; reg1d always stamped)
        // v0.4.4: 1d-skips carry FULL snapshot levels — the campaign's pseudo-
        // episodes must be walkable, or the 1D-gate question returns an empty set.
        f_emit("2A", "SKP", "L", math.round(time / 1000), close,
             f_t2_tail(hl_ref, stp, trend_high, "1d", wkp_lo, t2a_l_coin, rt1, (hl_ref - low) / atr, age_hl))
    else
        if na(rt1) or rt1 < rr_min
            f_emit("2A", "SKP", "L", math.round(time / 1000), close,
                 f_t2_tail(hl_ref, stp, trend_high, "rr", wkp_lo, t2a_l_coin, rt1, (hl_ref - low) / atr, age_hl))
        else
            string a_ent = f_t2_tail(hl_ref, stp, trend_high, "na", wkp_lo, t2a_l_coin, rt1, (hl_ref - low) / atr, age_hl)
            f_emit("2A", "ENT", "L", math.round(time / 1000), close, a_ent)
            f_mark("2A", "L", close, a_ent)
            t2a_ent_long := true
if swp_s and not na(trend_low)
    float stp = high + stop_buffer_atr * atr
    float rt1 = stp > close ? (close - trend_low) / (stp - close) : na
    if use_1d_gate and reg_1d == 1
        f_emit("2A", "SKP", "S", math.round(time / 1000), close,
             f_t2_tail(lh_ref, stp, trend_low, "1d", wkp_hi, t2a_s_coin, rt1, (high - lh_ref) / atr, age_lh))
    else
        if na(rt1) or rt1 < rr_min
            f_emit("2A", "SKP", "S", math.round(time / 1000), close,
                 f_t2_tail(lh_ref, stp, trend_low, "rr", wkp_hi, t2a_s_coin, rt1, (high - lh_ref) / atr, age_lh))
        else
            string a_ent_s = f_t2_tail(lh_ref, stp, trend_low, "na", wkp_hi, t2a_s_coin, rt1, (high - lh_ref) / atr, age_lh)
            f_emit("2A", "ENT", "S", math.round(time / 1000), close, a_ent_s)
            f_mark("2A", "S", close, a_ent_s)
            t2a_ent_short := true

// ════════════════ Trade #2B: chop-boundary sweep → fade to midpoint (spec §6B) ════════════════
// Requires BOTH walls (midpoint undefined otherwise — §3 seeding leaves the
// broken side na after a trend death; absent setups there are structural).
bool t2b_ent_long = false
bool t2b_ent_short = false
if barstate.isconfirmed and regime == 0 and not na(range_hi) and not na(range_lo)
    float mid = (range_hi + range_lo) / 2.0
    if low < range_lo and close >= range_lo         // §4 SWEEP of the low wall
        float stp = low - stop_buffer_atr * atr
        float rt1 = close > stp ? (mid - close) / (close - stp) : na
        if use_1d_gate and reg_1d == -1
            f_emit("2B", "SKP", "L", math.round(time / 1000), close,
                 f_t2_tail(range_lo, stp, mid, "1d", wkp_lo, false, rt1, (range_lo - low) / atr, age_rlo))
        else
            if na(rt1) or rt1 < rr_min               // the R gate IS the width gate (§3/§6B)
                f_emit("2B", "SKP", "L", math.round(time / 1000), close,
                     f_t2_tail(range_lo, stp, mid, "rr", wkp_lo, false, rt1, (range_lo - low) / atr, age_rlo))
            else
                string b_ent = f_t2_tail(range_lo, stp, mid, "na", wkp_lo, false, rt1, (range_lo - low) / atr, age_rlo)
                f_emit("2B", "ENT", "L", math.round(time / 1000), close, b_ent)
                f_mark("2B", "L", close, b_ent)
                t2b_ent_long := true
    if high > range_hi and close <= range_hi        // §4 SWEEP of the high wall
        float stp = high + stop_buffer_atr * atr
        float rt1 = stp > close ? (close - mid) / (stp - close) : na
        if use_1d_gate and reg_1d == 1
            f_emit("2B", "SKP", "S", math.round(time / 1000), close,
                 f_t2_tail(range_hi, stp, mid, "1d", wkp_hi, false, rt1, (high - range_hi) / atr, age_rhi))
        else
            if na(rt1) or rt1 < rr_min
                f_emit("2B", "SKP", "S", math.round(time / 1000), close,
                     f_t2_tail(range_hi, stp, mid, "rr", wkp_hi, false, rt1, (high - range_hi) / atr, age_rhi))
            else
                string b_ent_s = f_t2_tail(range_hi, stp, mid, "na", wkp_hi, false, rt1, (high - range_hi) / atr, age_rhi)
                f_emit("2B", "ENT", "S", math.round(time / 1000), close, b_ent_s)
                f_mark("2B", "S", close, b_ent_s)
                t2b_ent_short := true

// ════════════════ Trade OS: generalized sweep-reclaim (spec §14 v0.5) ════════════════
// One event per bar per direction at the DEEPEST swept-and-reclaimed level.
// Sweep grammar: low < lvl and close > lvl (strict reclaim; level as of prior bar).
// Roll class additionally requires the stretch gate (event-volume control, NOT a tuned edge).
float os_l_lvl = na
string os_l_src = "na"
int os_l_n = 0
float os_s_lvl = na
string os_s_src = "na"
int os_s_n = 0
if barstate.isconfirmed
    if os_use_piv and array.size(piv_lows) > 0      // v0.6: OFF by default (campaign-2 verdict)
        for i = 0 to array.size(piv_lows) - 1
            float lv = array.get(piv_lows, i)
            if low < lv and close > lv
                os_l_n += 1
                if na(os_l_lvl) or lv < os_l_lvl
                    os_l_lvl := lv
                    os_l_src := "piv"
    if not na(pdl) and low < pdl and close > pdl
        os_l_n += 1
        if na(os_l_lvl) or pdl < os_l_lvl
            os_l_lvl := pdl
            os_l_src := "pdl"
    if not na(pwl) and low < pwl and close > pwl
        os_l_n += 1
        if na(os_l_lvl) or pwl < os_l_lvl
            os_l_lvl := pwl
            os_l_src := "pwl"
    if os_use_roll and not na(roll_lo) and low < roll_lo and close > roll_lo and not na(os_min_m) and os_min_m <= -os_gate_atr
        os_l_n += 1
        if na(os_l_lvl) or roll_lo < os_l_lvl
            os_l_lvl := roll_lo
            os_l_src := "roll"
    if os_use_piv and array.size(piv_highs) > 0
        for i = 0 to array.size(piv_highs) - 1
            float lv = array.get(piv_highs, i)
            if high > lv and close < lv
                os_s_n += 1
                if na(os_s_lvl) or lv > os_s_lvl
                    os_s_lvl := lv
                    os_s_src := "piv"
    if not na(pdh) and high > pdh and close < pdh
        os_s_n += 1
        if na(os_s_lvl) or pdh > os_s_lvl
            os_s_lvl := pdh
            os_s_src := "pdh"
    if not na(pwh) and high > pwh and close < pwh
        os_s_n += 1
        if na(os_s_lvl) or pwh > os_s_lvl
            os_s_lvl := pwh
            os_s_src := "pwh"
    if os_use_roll and not na(roll_hi) and high > roll_hi and close < roll_hi and not na(os_max_m) and os_max_m >= os_gate_atr
        os_s_n += 1
        if na(os_s_lvl) or roll_hi > os_s_lvl
            os_s_lvl := roll_hi
            os_s_src := "roll"

// Same-bar coincidence with the kill-line sweep: emit BOTH, cross-flag oco=1 (dedup offline).
// 1D opposition = logged SKP only when use_1d_gate (default off — 2026-06-11 ruling, reg1d always stamped).
float os_mid = not na(range_hi) and not na(range_lo) ? (range_hi + range_lo) / 2.0 : na
if not na(os_l_lvl)
    string al = regime == 1 ? "W" : regime == -1 ? "A" : "N"
    int aget = os_l_src == "roll" ? age_roll_lo : os_l_src == "pdl" ? age_pdl : na
    float stp = low - stop_buffer_atr * atr
    // v0.6.2 alignment-aware target: with-regime -> trend extreme (2A's proven target);
    // against-regime -> fair-value anchor (reversion thesis); chop -> range midpoint (2B's).
    float t1px = regime == 1 ? trend_high : regime == 0 ? os_mid : lr_anchor
    string tgt = regime == 1 ? "tex" : regime == 0 ? "mid" : "fv"
    float swd = (os_l_lvl - low) / atr
    float rt1 = close > stp and not na(t1px) and t1px > close ? (t1px - close) / (close - stp) : na
    if use_1d_gate and reg_1d == -1
        f_emit("OS", "SKP", "L", math.round(time / 1000), close,
             f_os_tail(os_l_lvl, stp, t1px, "1d", os_l_src, os_l_n, al, swp_l, swd, aget, rt1, tgt))
    else if na(rt1) or rt1 < rr_min
        f_emit("OS", "SKP", "L", math.round(time / 1000), close,
             f_os_tail(os_l_lvl, stp, t1px, "rr", os_l_src, os_l_n, al, swp_l, swd, aget, rt1, tgt))
    else
        string os_ent = f_os_tail(os_l_lvl, stp, t1px, "na", os_l_src, os_l_n, al, swp_l, swd, aget, rt1, tgt)
        f_emit("OS", "ENT", "L", math.round(time / 1000), close, os_ent)
        f_mark_os("L", close, os_ent, al)
if not na(os_s_lvl)
    string al = regime == -1 ? "W" : regime == 1 ? "A" : "N"
    int aget = os_s_src == "roll" ? age_roll_hi : os_s_src == "pdh" ? age_pdh : na
    float stp = high + stop_buffer_atr * atr
    float t1px = regime == -1 ? trend_low : regime == 0 ? os_mid : lr_anchor
    string tgt = regime == -1 ? "tex" : regime == 0 ? "mid" : "fv"
    float swd = (high - os_s_lvl) / atr
    float rt1 = stp > close and not na(t1px) and t1px < close ? (close - t1px) / (stp - close) : na
    if use_1d_gate and reg_1d == 1
        f_emit("OS", "SKP", "S", math.round(time / 1000), close,
             f_os_tail(os_s_lvl, stp, t1px, "1d", os_s_src, os_s_n, al, swp_s, swd, aget, rt1, tgt))
    else if na(rt1) or rt1 < rr_min
        f_emit("OS", "SKP", "S", math.round(time / 1000), close,
             f_os_tail(os_s_lvl, stp, t1px, "rr", os_s_src, os_s_n, al, swp_s, swd, aget, rt1, tgt))
    else
        string os_ent_s = f_os_tail(os_s_lvl, stp, t1px, "na", os_s_src, os_s_n, al, swp_s, swd, aget, rt1, tgt)
        f_emit("OS", "ENT", "S", math.round(time / 1000), close, os_ent_s)
        f_mark_os("S", close, os_ent_s, al)

// ════════════════ Rendering (§11 — minimal by design) ════════════════
// Two always-on structure lines with seeded continuity across transitions:
// UP→CHOP hands trend_high to range_hi; CHOP→UP hands range_hi to trend_high;
// mirrors for DOWN. The OPAQUE line is the kill line (body close beyond it
// changes the regime); the faded line is passive context (T1 reference in a
// trend). A line only breaks where a level is genuinely undefined (fresh-chop
// broken side, pre-history).
upper_lvl = regime == 1 ? trend_high : regime == -1 ? lh_ref : range_hi
lower_lvl = regime == 1 ? hl_ref : regime == -1 ? trend_low : range_lo
upper_col = regime == 1 ? color.new(color.teal, 65) : regime == -1 ? color.new(color.red, 0) : color.new(color.orange, 25)
lower_col = regime == 1 ? color.new(color.green, 0) : regime == -1 ? color.new(color.teal, 65) : color.new(color.orange, 25)
plot(upper_lvl, "Structure: upper", upper_col, 2, plot.style_stepline)
plot(lower_lvl, "Structure: lower", lower_col, 2, plot.style_stepline)
bgcolor(regime == 1 ? color.new(color.green, 88) : regime == -1 ? color.new(color.red, 88) : na)
// Entry marks are now f_mark labels (T1/2A/2B tags with hover cards) — the
// plotshape triangles/diamonds were replaced in v0.4.2.

// ════════════════ Data Window (per-bar inspection; hidden from the chart) ════════════════
// Crosshair any bar → TV's Data Window panel shows the live state + factors.
plot(regime,     "DW regime (1=up 0=chop -1=dn)", display = display.data_window)
plot(regime_age, "DW regime age (bars)",          display = display.data_window)
plot(reg_1d,     "DW 1D regime",                  display = display.data_window)
plot(atr,        "DW ATR14",                      display = display.data_window)
plot(oi,         "DW open interest",              display = display.data_window)
plot(oi_chg,     "DW OI chg % (bar)",             display = display.data_window)
plot(prem,       "DW premium",                    display = display.data_window)
plot(fp,         "DW funding pctile",             display = display.data_window)
plot(wkp_lo,     "DW wick pctile (lower)",        display = display.data_window)
plot(wkp_hi,     "DW wick pctile (upper)",        display = display.data_window)
plot(q_dpx >= 0 ? 1 : -1, "DW quad dPrice sign",  display = display.data_window)
plot(na(q_doi) ? na : q_doi >= 0 ? 1 : -1, "DW quad dOI sign", display = display.data_window)
plot(regime == 1 ? f_gvb(hl_ref) : regime == -1 ? f_gvb(lh_ref) : na,
     "DW giveback vs kill line (ATR)",            display = display.data_window)
plot(os_raw, "DW overshoot (ATR, signed)",  display = display.data_window)
plot(er,     "DW efficiency ratio",          display = display.data_window)
plot(vz,     "DW volume z-score",            display = display.data_window)
plot(dlt,    "DW volume delta (60m CVD)",    display = display.data_window)
plot(fr,     "DW funding rate",              display = display.data_window)
plot(lqb,    "DW liq buy (shorts closed)",   display = display.data_window)
plot(lqs,    "DW liq sell (longs closed)",   display = display.data_window)

var table vt = table.new(position.top_right, 1, 1)
if barstate.islast
    table.cell(vt, 0, 0, "Jamal Fable v" + SCRIPT_V + " · schema " + SCHEMA_V + " · cfg " + str.tostring(cfg_i) + " · 1D " + f_reg_str(reg_1d),
         text_color = color.white, bgcolor = color.new(color.black, 20), text_size = size.small)
